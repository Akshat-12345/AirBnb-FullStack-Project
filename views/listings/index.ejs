<%= layout("/layouts/boiler_plate.ejs") %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>
  :root {
    --atithi-orange: #FF9432;
    --atithi-green: #67B636;
    --atithi-blue: #00A3E0;
    --airbnb-red: #FF385C; 
    --text-slate-dark: #222222; 
    --text-slate-muted: #717171; 
    --font-premium-stack: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  body {
    background-color: #ffffff !important; 
    font-family: var(--font-premium-stack);
    -webkit-font-smoothing: antialiased;
    letter-spacing: -0.1px;
    overflow-x: hidden;
  }

  /* === 🚀 GLOBAL AUTOMATED SCROLLBAR MECHANICS === */
  ::-webkit-scrollbar {
    width: 8px;
    height: 6px;
    background-color: rgba(15, 23, 42, 0.02);
  }
  ::-webkit-scrollbar-track {
    background: rgba(15, 23, 42, 0.05);
    backdrop-filter: blur(10px);
  }
  ::-webkit-scrollbar-thumb {
    background: linear-gradient(180deg, var(--atithi-orange) 0%, var(--atithi-green) 50%, var(--atithi-blue) 100%);
    border-radius: 100px;
  }

  .categories::-webkit-scrollbar {
    display: none;
  }

  /* === 🌟 1. CATEGORIES CONTAINER CONSOLE === */
  .filter-bar-container {
    padding: 24px 0 0 0;
    margin-bottom: 1.5rem;
    background: #ffffff;
    border-bottom: 1px solid #f7f7f7;
    position: sticky;
    top: 80px;
    z-index: 999;
  }
  
  .filter-bar {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto; 
    align-items: center;
    gap: 2rem; 
  }
  
  .categories {
    display: flex;
    gap: 2.2rem;
    overflow-x: auto;
    scrollbar-width: none;
  }
  
  .category {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: #717171 !important;
    opacity: 0.65;
    white-space: nowrap;
    padding-bottom: 12px;
    position: relative;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }
  
  .category i {
    font-size: 1.35rem; 
  }
  
  .category span {
    font-size: 12px;
    font-weight: 500;
  }
  
  .category:hover {
    color: #000000 !important;
    opacity: 1;
    transform: translateY(-2px);
  }
  
  .category.active {
    color: #000000 !important;
    opacity: 1;
    font-weight: 600;
  }
  
  .category.active::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: #222222;
  }

  /* === ⚡ 2. INNOVATIVE GLOWING INTERACTIVE TAX TOGGLE === */
  .filter-controls {
    display: flex;
    align-items: center;
  }

  .premium-tax-box {
    display: flex;
    align-items: center;
    gap: 14px;
    border: 1px solid #e2e8f0;
    padding: 10px 18px;
    border-radius: 16px;
    background-color: #ffffff;
    user-select: none;
    position: relative;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
  }

  .premium-tax-box:hover {
    border-color: #b0b0b0;
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.04);
  }

  /* 🚀 INNOVATION: Glowing Dynamic Border Animation class on Active State */
  .premium-tax-box.glow-active {
    border-color: transparent;
    background: linear-gradient(#ffffff, #ffffff) padding-box,
                linear-gradient(90deg, var(--atithi-orange), var(--atithi-green), var(--atithi-blue)) border-box;
    box-shadow: 0 0 20px rgba(0, 163, 224, 0.18);
  }

  .tax-meta-block {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  
  .tax-meta-block i {
    font-size: 16px;
    color: #475569;
    transition: all 0.3s ease;
  }
  
  .premium-tax-box.glow-active .tax-meta-block i {
    color: var(--atithi-orange);
    transform: scale(1.1) rotate(-5deg);
  }

  .tax-catchy-text {
    font-size: 13.5px;
    font-weight: 600;
    color: #222222;
    white-space: nowrap;
    letter-spacing: -0.1px;
    transition: color 0.3s ease;
  }

  .premium-tax-box.glow-active .tax-catchy-text {
    color: #000000;
  }

  /* PURE CSS ULTRA-PREMIUM SLIDER GENERATOR */
  .custom-switch-wrapper {
    position: relative;
    width: 48px;
    height: 26px;
  }
  
  .custom-switch-wrapper input {
    opacity: 0;
    width: 0;
    height: 0;
  }

  .custom-slider {
    position: absolute;
    cursor: pointer;
    inset: 0;
    background-color: #e2e8f0;
    border-radius: 34px;
    border: 1px solid rgba(0,0,0,0.02);
    transition: background-color 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  /* Inner Switch Ball Design Architecture */
  .custom-slider::before {
    content: "\F26E"; /* Bootstrap check icon glyph code fallback */
    font-family: "bootstrap-icons";
    font-size: 10px;
    font-weight: 900;
    color: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    
    position: absolute;
    height: 20px;
    width: 20px;
    left: 2px;
    bottom: 2px;
    background-color: white;
    border-radius: 50%;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), background-color 0.3s ease;
    box-shadow: 0 2px 5px rgba(0,0,0,0.15);
  }

  input:checked + .custom-slider {
    background: linear-gradient(135deg, #222222 0%, #111111 100%);
  }
  
  /* Kinetic glide + inside micro check icon popping transition */
  input:checked + .custom-slider::before {
    transform: translateX(22px);
    color: #222222;
    content: "\F26E"; 
  }

  .tax-toggle:active {
    transform: scale(0.97);
  }

  /* === 🌟 3. CINEMA GRID GENERATION ENGINE (UNTOUCHED PREMIUM CARDS) === */
  .atithi-outer-wrapper {
    padding: 0 2% !important; 
    width: 100%;
    max-width: 100vw;
    box-sizing: border-box;
  }

  .atithi-grid-engine {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 20px; 
    width: 100%;
  }

  .atithi-premium-card {
    background: transparent !important; 
    border: none !important; 
    border-radius: 0 !important;
    box-shadow: none !important; 
    width: 100%;
    position: relative;
    opacity: 0;
    transform: translateY(15px);
    animation: cardEntranceCascade 0.5s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
  }

  @keyframes cardEntranceCascade {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .image-wrapper-node {
    position: relative;
    overflow: hidden;
    border-radius: 14px; 
    width: 100%;
    aspect-ratio: 20 / 19; 
    background-color: #f3f4f6;
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
  }

  .card-img-top {
    height: 100%;
    object-fit: cover;
    width: 100%;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94); 
  }
  
  .atithi-premium-card:hover .card-img-top {
    transform: scale(1.06);
  }

  .fav-btn-pod {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 10;
  }
  .fav-btn {
    background: transparent !important;
    border: none;
    font-size: 1.45rem;
    color: rgba(0, 0, 0, 0.45); 
    -webkit-text-stroke: 2px #ffffff; 
    transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    cursor: pointer;
  }
  .fav-btn:hover {
    transform: scale(1.15);
    color: var(--airbnb-red) !important;
    -webkit-text-stroke: 2px var(--airbnb-red);
  }

  .arrived-new-banner {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 10;
    background: linear-gradient(135deg, var(--airbnb-red) 0%, #ff527b 100%); 
    color: #ffffff;
    font-size: 11px;
    font-weight: 700;
    padding: 5px 12px;
    border-radius: 6px;
    box-shadow: 0 6px 15px rgba(255, 56, 92, 0.3);
    letter-spacing: 0.2px;
    text-transform: uppercase;
  }

  .card-body-meta {
    padding: 12px 0 0 0; 
  }

  .meta-title-rating-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 8px;
    margin-bottom: 2px;
  }

  .listing-title-text {
    font-size: 14.5px;
    font-weight: 600; 
    color: var(--text-slate-dark);
    margin-bottom: 0;
    text-overflow: ellipsis;
    white-space: nowrap;
    overflow: hidden;
    line-height: 19px;
  }

  .rating-badge-container {
    font-size: 14px;
    font-weight: 400;
    color: var(--text-slate-dark);
    display: flex;
    align-items: center;
    gap: 4px;
    line-height: 19px;
    flex-shrink: 0;
  }
  .rating-badge-container i {
    font-size: 11px;
    color: #222222; 
  }

  .listing-geo-text {
    font-size: 14px;
    color: var(--text-slate-muted);
    font-weight: 400;
    margin-bottom: 2px;
    line-height: 18px;
  }

  .listing-pricing-node {
    font-size: 14.5px;
    font-weight: 400;
    color: var(--text-slate-dark);
    line-height: 19px;
    margin-bottom: 0;
  }
  .listing-pricing-node strong {
    font-weight: 600;
  }

  .tax-info {
    display: none;
    font-size: 14px;
    font-weight: 400;
    color: var(--text-slate-muted);
    margin-top: 4px;
    line-height: 18px;
    text-decoration: underline;
    opacity: 0;
    transform: translateY(5px);
    transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .tax-info.visible-tax {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }

  .tax-amount-highlight {
    font-weight: 600;
    color: var(--text-slate-dark);
  }

  @media (max-width: 1700px) {
    .atithi-grid-engine { grid-template-columns: repeat(6, minmax(0, 1fr)); }
  }
  @media (max-width: 1450px) {
    .atithi-grid-engine { grid-template-columns: repeat(5, minmax(0, 1fr)); }
  }
  @media (max-width: 1200px) {
    .atithi-grid-engine { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }
  @media (max-width: 992px) {
    .atithi-grid-engine { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .filter-bar { grid-template-columns: 1fr; gap: 1.2rem; }
    .categories { width: 100%; gap: 1.8rem; padding-bottom: 10px; }
    .filter-controls { width: 100%; }
    .premium-tax-box { width: 100%; justify-content: space-between; }
  }
  @media (max-width: 768px) {
    .atithi-outer-wrapper { padding: 0 20px !important; }
    .atithi-grid-engine { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 480px) {
    .atithi-grid-engine { grid-template-columns: repeat(1, minmax(0, 1fr)); }
  }
</style>

<!-- IMMERSIVE CATEGORY NAV MODULE -->
<div class="atithi-outer-wrapper">
  <div class="filter-bar-container">
    <div class="filter-bar">
      
      <div class="categories">
        <a href="/listings" class="category <%= selectedCategory === 'Trending' ? 'active' : '' %>">
          <i class="fa-solid fa-fire"></i><span>Trending</span>
        </a>
        <a href="/listings?category=Rooms" class="category <%= selectedCategory === 'Rooms' ? 'active' : '' %>">
          <i class="fa-solid fa-bed"></i><span>Rooms</span>
        </a>
        <a href="/listings?category=Amazing views" class="category <%= selectedCategory === 'Amazing views' ? 'active' : '' %>">
          <i class="fa-solid fa-mountain-sun"></i><span>Amazing views</span>
        </a>
        <a href="/listings?category=Mansions" class="category <%= selectedCategory === 'Mansions' ? 'active' : '' %>">
          <i class="fa-solid fa-building-columns"></i><span>Mansions</span>
        </a>
        <a href="/listings?category=Amazing pools" class="category <%= selectedCategory === 'Amazing pools' ? 'active' : '' %>">
          <i class="fa-solid fa-person-swimming"></i><span>Amazing pools</span>
        </a>
        <a href="/listings?category=Beach" class="category <%= selectedCategory === 'Beach' ? 'active' : '' %>">
          <i class="fa-solid fa-umbrella-beach"></i><span>Beach</span>
        </a>
        <a href="/listings?category=Cabins" class="category <%= selectedCategory === 'Cabins' ? 'active' : '' %>">
          <i class="fa-solid fa-house-chimney-window"></i><span>Cabins</span>
        </a>
        <a href="/listings?category=Camping" class="category <%= selectedCategory === 'Camping' ? 'active' : '' %>">
          <i class="fa-solid fa-campground"></i><span>Camping</span>
        </a>
        <a href="/listings?category=Farms" class="category <%= selectedCategory === 'Farms' ? 'active' : '' %>">
          <i class="fa-solid fa-tractor"></i><span>Farms</span>
        </a>
      </div>

      <!-- DYNAMIC ATTRACTIVE GLOW TOGGLE ACCENT BOX -->
      <div class="filter-controls">
        <div class="premium-tax-box" id="taxBoxTrigger">
          <div class="tax-meta-block">
            <i class="fa-solid fa-receipt"></i>
            <span class="tax-catchy-text">Display Total Price (With Taxes)</span>
          </div>
          <div class="custom-switch-wrapper">
            <input type="checkbox" id="taxToggle">
            <span class="custom-slider"></span>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</div>

<!-- 🌟 ULTIMATE COLUMNS FLUID CINEMA GRID MATRIX -->
<div class="atithi-outer-wrapper mt-2 mb-5">
  <div class="atithi-grid-engine">
    <% datas.forEach((data, index) => { %>
      <div class="atithi-premium-card" style="animation-delay: <%= index * 0.04 %>s">
        
        <div class="image-wrapper-node">
          <% 
            let displayUrl = "/images/default.jpg";
            if(data.images && data.images.length > 0 && data.images[0].url) {
              displayUrl = data.images[0].url.replace('/upload', '/upload/w_350,h_330,c_fill,q_auto,f_auto');
            }
          %>
          <img 
            src="<%= displayUrl %>" 
            class="card-img-top" 
            alt="Listing Asset Scenery">
          
          <% if(!data.reviews || data.reviews.length === 0) { %>
            <div class="arrived-new-banner">Arrived new</div>
          <% } %>

          <div class="fav-btn-pod">
            <button class="fav-btn"><i class="fa-solid fa-heart"></i></button>
          </div>
        </div>

        <div class="card-body-meta">
          <div class="meta-title-rating-row">
            <h6 class="listing-title-text"><%= data.title %></h6>
            
            <% if(data.reviews && data.reviews.length > 0) { %>
              <% 
                let sum = 0; 
                data.reviews.forEach(r => sum += r.rating); 
                let avg = (sum / data.reviews.length).toFixed(1); 
              %>
              <div class="rating-badge-container">
                <i class="fa-solid fa-star"></i><span><%= avg %></span>
              </div>
            <% } else { %>
              <div class="rating-badge-container">
                <i class="fa-solid fa-star"></i><span>New</span>
              </div>
            <% } %>
          </div>

          <p class="listing-geo-text"><%= data.location %>, <%= data.country %></p>
          <p class="listing-pricing-node"><strong>₹<%= data.price.toLocaleString("en-IN") %></strong> / night</p>
          
          <% 
            let taxAmount = Math.round(data.price * 0.12);
            let totalWithTax = data.price + taxAmount;
          %>
          <div class="tax-info">
            <span class="tax-amount-highlight">₹<%= totalWithTax.toLocaleString("en-IN") %></span> total after 12% GST
          </div>
          
          <a href="/listings/<%= data._id %>" class="stretched-link"></a>
        </div>

      </div>
    <% }) %>
  </div>
</div>

<script>
  const taxBoxTrigger = document.getElementById('taxBoxTrigger');
  const toggleSwitch = document.getElementById('taxToggle');

  taxBoxTrigger.addEventListener('click', (e) => {
    if (e.target !== toggleSwitch) {
      toggleSwitch.checked = !toggleSwitch.checked;
    }
    triggerTaxVisibility();
  });

  function triggerTaxVisibility() {
    let taxInfoTags = document.getElementsByClassName('tax-info');
    
    // Toggle Dynamic Multi-color Border Glow Class
    if(toggleSwitch.checked) {
      taxBoxTrigger.classList.add('glow-active');
    } else {
      taxBoxTrigger.classList.remove('glow-active');
    }

    for(let info of taxInfoTags) {
      if(toggleSwitch.checked) {
        info.style.display = 'block';
        setTimeout(() => info.classList.add('visible-tax'), 10);
      } else {
        info.classList.remove('visible-tax');
        setTimeout(() => info.style.display = 'none', 300);
      }
    }
  }
  
</script>
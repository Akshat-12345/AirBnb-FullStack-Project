<%= layout("/layouts/boiler_plate.ejs") %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>
  :root {
    --atithi-orange: #FF9432;
    --atithi-green: #67B636;
    --atithi-blue: #00A3E0;
    --airbnb-red: #FF385C; 
    --text-slate-dark: #222222; 
    --text-slate-muted: #717171; 
    --font-premium-stack: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  body {
    background-color: #ffffff !important; 
    font-family: var(--font-premium-stack);
    -webkit-font-smoothing: antialiased;
    letter-spacing: -0.1px;
    overflow-x: hidden;
  }

  /* === 🚀 GLOBAL AUTOMATED GLOWING SCROLLBAR MECHANICS === */
  ::-webkit-scrollbar {
    width: 8px;
    height: 6px;
    background-color: rgba(15, 23, 42, 0.02);
  }
  ::-webkit-scrollbar-track {
    background: rgba(15, 23, 42, 0.05);
    backdrop-filter: blur(10px);
  }
  ::-webkit-scrollbar-thumb {
    background: linear-gradient(180deg, var(--atithi-orange) 0%, var(--atithi-green) 50%, var(--atithi-blue) 100%);
    border-radius: 100px;
  }

  /* Separate optimized fine-rail scroll tracker for the horizontal navigation block */
  .categories::-webkit-scrollbar {
    height: 4px;
    background-color: transparent;
  }
  .categories::-webkit-scrollbar-thumb {
    background: linear-gradient(90deg, var(--atithi-orange) 0%, var(--atithi-green) 100%);
    border-radius: 100px;
  }

  /* === 🌟 1. ADVANCED CATEGORIES NAV CONSOLE === */
  .filter-bar-container {
    padding: 20px 0 10px 0;
    margin-bottom: 1.5rem;
    background: #ffffff;
    border-bottom: 1px solid #f7f7f7;
  }
  
  .filter-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3rem; 
  }
  
  .categories {
    flex: 1; 
    display: flex;
    gap: 2.5rem;
    overflow-x: auto;
    -ms-overflow-style: auto;
    scrollbar-width: thin;
    padding-bottom: 8px;
  }
  
  .category {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: #717171;
    white-space: nowrap;
    padding-bottom: 12px;
    position: relative;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    flex-shrink: 0;
  }
  
  .category i {
    font-size: 1.45rem;
    transition: transform 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  
  .category span {
    font-size: 12px;
    font-weight: 600;
  }
  
  .category:hover {
    color: #000000;
  }
  .category:hover i {
    transform: translateY(-4px) scale(1.05); /* Premium kinetic pop animation */
  }
  
  .category.active {
    color: #000000;
    font-weight: 700;
  }
  .category.active::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2.5px;
    border-radius: 10px;
    background: linear-gradient(90deg, var(--atithi-orange) 0%, var(--atithi-green) 50%, var(--atithi-blue) 100%);
    box-shadow: 0 2px 8px rgba(103, 182, 54, 0.3);
  }

  /* === 🌟 2. TAX CONTROLS SYSTEM DECK === */
  .filter-controls {
    flex-shrink: 0; 
    display: flex;
    align-items: center;
  }

  .tax-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px; 
    border: 1px solid #EBEBEB;
    padding: 14px 24px;
    border-radius: 14px;
    background: #ffffff;
    white-space: nowrap;
    min-width: 310px; 
    transition: all 0.25s ease;
  }
  .tax-toggle:hover {
    border-color: #b0b0b0;
    box-shadow: 0 6px 20px rgba(0,0,0,0.04);
  }
  
  .tax-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-slate-dark);
    user-select: none;
  }

  .form-switch {
    padding-left: 0 !important;
    margin-bottom: 0 !important;
    display: flex;
    align-items: center;
  }

  .form-switch .form-check-input {
    width: 3.2em;
    height: 1.75em;
    cursor: pointer;
    background-color: #b0b0b0;
    border-color: transparent;
    border-radius: 2em;
    position: relative;
    margin-top: 0 !important;
    transition: all 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .form-switch .form-check-input::after {
    content: "";
    position: absolute;
    height: 1.25em;
    width: 1.25em;
    border-radius: 50%;
    background-color: white;
    top: 50%;
    left: 0.25em;
    transform: translateY(-50%);
    transition: transform 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 2px 5px rgba(15, 23, 42, 0.15);
  }
  .form-switch .form-check-input:checked {
    background-color: #222222 !important;
  }
  .form-switch .form-check-input:checked::after {
    transform: translateY(-50%) translateX(1.4em); 
  }

  /* === 🌟 3. CINEMA GRID GENERATION ENGINE (HARD SPEC: EXACT 7 COLUMNS) === */
  .atithi-outer-wrapper {
    padding: 0 2% !important; 
    width: 100%;
    max-width: 100vw;
    box-sizing: border-box;
  }

  .atithi-grid-engine {
    display: grid;
    /* 🌟 THE BREAKOUT OVERHAUL: Fluid allocation for exact 7 listings per horizontal line on large screens */
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 20px; /* Compressed slightly to maintain golden ratio boundaries */
    width: 100%;
  }

  /* Premium Cascade Entrance Fade-In Stagger Animation for Cards Loading Lifecycle */
  .atithi-premium-card {
    background: transparent !important; 
    border: none !important; 
    border-radius: 0 !important;
    box-shadow: none !important; 
    width: 100%;
    position: relative;
    opacity: 0;
    transform: translateY(15px);
    animation: cardEntranceCascade 0.5s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
  }

  @keyframes cardEntranceCascade {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .image-wrapper-node {
    position: relative;
    overflow: hidden;
    border-radius: 14px; 
    width: 100%;
    aspect-ratio: 20 / 19; 
    background-color: #f3f4f6;
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
  }

  .card-img-top {
    height: 100%;
    object-fit: cover;
    width: 100%;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94); /* Smooth kinetic zoom engine */
  }
  
  /* 🚀 INTENSE UX ENHANCEMENT: Architectural Zoom Layer on Hover */
  .atithi-premium-card:hover .card-img-top {
    transform: scale(1.06);
  }

  /* Heart Bookmark Trigger with Pop-Reaction Animation */
  .fav-btn-pod {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 10;
  }
  .fav-btn {
    background: transparent !important;
    border: none;
    font-size: 1.45rem;
    color: rgba(0, 0, 0, 0.45); 
    -webkit-text-stroke: 2px #ffffff; 
    transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    cursor: pointer;
  }
  .fav-btn:hover {
    transform: scale(1.15);
    color: var(--airbnb-red) !important;
    -webkit-text-stroke: 2px var(--airbnb-red);
  }

  /* Premium Micro Red Banner Tag Inside Image Container Bounds */
  .arrived-new-banner {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 10;
    background: linear-gradient(135deg, var(--airbnb-red) 0%, #ff527b 100%); 
    color: #ffffff;
    font-size: 11px;
    font-weight: 700;
    padding: 5px 12px;
    border-radius: 6px;
    box-shadow: 0 6px 15px rgba(255, 56, 92, 0.3);
    letter-spacing: 0.2px;
    text-transform: uppercase;
  }

  /* TYPOGRAPHY HIERARCHY MAPS */
  .card-body-meta {
    padding: 12px 0 0 0; 
  }

  .meta-title-rating-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 8px;
    margin-bottom: 2px;
  }

  .listing-title-text {
    font-size: 14.5px;
    font-weight: 600; 
    color: var(--text-slate-dark);
    margin-bottom: 0;
    text-overflow: ellipsis;
    white-space: nowrap;
    overflow: hidden;
    line-height: 19px;
  }

  .rating-badge-container {
    font-size: 14px;
    font-weight: 400;
    color: var(--text-slate-dark);
    display: flex;
    align-items: center;
    gap: 4px;
    line-height: 19px;
    flex-shrink: 0;
  }
  .rating-badge-container i {
    font-size: 11px;
    color: #222222; 
  }

  .listing-geo-text {
    font-size: 14px;
    color: var(--text-slate-muted);
    font-weight: 400;
    margin-bottom: 2px;
    line-height: 18px;
  }

  .listing-pricing-node {
    font-size: 14.5px;
    font-weight: 400;
    color: var(--text-slate-dark);
    line-height: 19px;
    margin-bottom: 0;
  }
  .listing-pricing-node strong {
    font-weight: 600;
  }

  /* Smooth Slide-In Reveal Fade for Taxes notation block */
  .tax-info {
    display: none;
    font-size: 14px;
    font-weight: 400;
    color: var(--text-slate-muted);
    margin-top: 4px;
    line-height: 18px;
    text-decoration: underline;
    animation: taxRevealFade 0.25s ease-out forwards;
  }

  @keyframes taxRevealFade {
    from { opacity: 0; transform: translateY(2px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .tax-amount-highlight {
    font-weight: 600;
    color: var(--text-slate-dark);
  }

  /* === 🪐 MULTI-DEVICE RESPONSIVE SCALE SYSTEM GRID === */
  @media (max-width: 1700px) {
    .atithi-grid-engine { grid-template-columns: repeat(6, minmax(0, 1fr)); }
  }
  @media (max-width: 1450px) {
    .atithi-grid-engine { grid-template-columns: repeat(5, minmax(0, 1fr)); }
  }
  @media (max-width: 1200px) {
    .atithi-grid-engine { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .tax-toggle { min-width: auto; }
  }
  @media (max-width: 992px) {
    .atithi-grid-engine { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (max-width: 768px) {
    .atithi-outer-wrapper { padding: 0 20px !important; }
    .filter-bar { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .categories { width: 100%; gap: 1.8rem; padding-bottom: 10px; }
    .filter-controls { width: 100%; }
    .tax-toggle { width: 100%; }
    .atithi-grid-engine { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 480px) {
    .atithi-grid-engine { grid-template-columns: repeat(1, minmax(0, 1fr)); }
  }
</style>

<!-- IMMERSIVE CATEGORY NAV MODULE -->
<div class="atithi-outer-wrapper">
  <div class="filter-bar-container">
    <div class="filter-bar">
      
      <div class="categories">
        <a href="/listings" class="category <%= selectedCategory === 'Trending' ? 'active' : '' %>">
          <i class="fa-solid fa-fire" style="color: var(--atithi-orange);"></i><span>Trending</span>
        </a>
        <a href="/listings?category=Rooms" class="category <%= selectedCategory === 'Rooms' ? 'active' : '' %>">
          <i class="fa-solid fa-bed" style="color: #6366f1;"></i><span>Rooms</span>
        </a>
        <a href="/listings?category=Amazing views" class="category <%= selectedCategory === 'Amazing views' ? 'active' : '' %>">
          <i class="fa-solid fa-mountain-sun" style="color: var(--atithi-blue);"></i><span>Amazing views</span>
        </a>
        <a href="/listings?category=Mansions" class="category <%= selectedCategory === 'Mansions' ? 'active' : '' %>">
          <i class="fa-solid fa-building-columns" style="color: #a855f7;"></i><span>Mansions</span>
        </a>
        <a href="/listings?category=Amazing pools" class="category <%= selectedCategory === 'Amazing pools' ? 'active' : '' %>">
          <i class="fa-solid fa-person-swimming" style="color: #06b6d4;"></i><span>Amazing pools</span>
        </a>
        <a href="/listings?category=Beach" class="category <%= selectedCategory === 'Beach' ? 'active' : '' %>">
          <i class="fa-solid fa-umbrella-beach" style="color: #f59e0b;"></i><span>Beach</span>
        </a>
        <a href="/listings?category=Cabins" class="category <%= selectedCategory === 'Cabins' ? 'active' : '' %>">
          <i class="fa-solid fa-house-chimney-window" style="color: #10b981;"></i><span>Cabins</span>
        </a>
        <a href="/listings?category=Camping" class="category <%= selectedCategory === 'Camping' ? 'active' : '' %>">
          <i class="fa-solid fa-campground" style="color: var(--atithi-green);"></i><span>Camping</span>
        </a>
        <a href="/listings?category=Farms" class="category <%= selectedCategory === 'Farms' ? 'active' : '' %>">
          <i class="fa-solid fa-tractor" style="color: #84cc16;"></i><span>Farms</span>
        </a>
      </div>

      <!-- FIXED: STABILIZED WIDE FRAME FOR TOGGLE CONTROL -->
      <div class="filter-controls">
        <div class="tax-toggle">
          <span class="tax-label">Display total before taxes</span>
          <div class="form-check form-switch m-0 p-0">
            <input class="form-check-input" type="checkbox" role="switch" id="taxToggle">
          </div>
        </div>
      </div>
      
    </div>
  </div>
</div>

<!-- 🌟 ULTIMATE 7-COLUMN FLUID CINEMA GRID MATRIX -->
<div class="atithi-outer-wrapper mt-2 mb-5">
  <div class="atithi-grid-engine">
    <% datas.forEach((data, index) => { %>
      <!-- Staggered delay injection via inline styles to produce organic cascade loading feel -->
      <div class="atithi-premium-card" style="animation-delay: <%= index * 0.04 %>s">
        
        <!-- Image Housing Anchor Container -->
        <div class="image-wrapper-node">
          <img 
            src="<%= data.image && data.image.url ? data.image.url.replace('/upload', '/upload/w_350,h_330,c_fill,q_auto,f_auto') : '/images/default.jpg' %>" 
            class="card-img-top" 
            alt="Listing Asset Scenery">
          
          <!-- Pristine Red Capitalized Badge sitting left-top area inside image bounds -->
          <% if(!data.reviews || data.reviews.length === 0) { %>
            <div class="arrived-new-banner">Arrived new</div>
          <% } %>

          <div class="fav-btn-pod">
            <button class="fav-btn"><i class="fa-solid fa-heart"></i></button>
          </div>
        </div>

        <!-- Metadata Details Content Frame -->
        <div class="card-body-meta">
          
          <!-- Line 1: Title & Rating Side-by-Side -->
          <div class="meta-title-rating-row">
            <h6 class="listing-title-text"><%= data.title %></h6>
            
            <% if(data.reviews && data.reviews.length > 0) { %>
              <% 
                let sum = 0; 
                data.reviews.forEach(r => sum += r.rating); 
                let avg = (sum / data.reviews.length).toFixed(1); 
              %>
              <div class="rating-badge-container">
                <i class="fa-solid fa-star"></i><span><%= avg %></span>
              </div>
            <% } else { %>
              <div class="rating-badge-container">
                <i class="fa-solid fa-star"></i><span>New</span>
              </div>
            <% } %>
          </div>

          <!-- Line 2: Subtle Muted Geographical Subtext -->
          <p class="listing-geo-text"><%= data.location %>, <%= data.country %></p>
          
          <!-- Line 3: Exact Standardized Price Parameters Layout -->
          <p class="listing-pricing-node"><strong>₹<%= data.price.toLocaleString("en-IN") %></strong> / night</p>
          
          <!-- Line 4: Clean Dynamic Compound 12% GST Tax Calculator Token Line -->
          <% 
            let taxAmount = Math.round(data.price * 0.12);
            let totalWithTax = data.price + taxAmount;
          %>
          <div class="tax-info">
            <span class="tax-amount-highlight">₹<%= totalWithTax.toLocaleString("en-IN") %></span> total after 12% GST
          </div>
          
          <a href="/listings/<%= data._id %>" class="stretched-link"></a>
        </div>

      </div>
    <% }) %>
  </div>
</div>

<script>
  // Ultra Smooth Switch Transition Logic Multiplexer
  let toggleSwitch = document.getElementById('taxToggle');
  toggleSwitch.addEventListener('change', () => {
    let taxInfoTags = document.getElementsByClassName('tax-info');
    for(let info of taxInfoTags) {
      if(toggleSwitch.checked) {
        info.style.display = 'block';
      } else {
        info.style.display = 'none';
      }
    }
  });
</script>
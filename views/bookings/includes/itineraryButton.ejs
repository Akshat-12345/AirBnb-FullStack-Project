<!-- views/bookings/includes/itineraryButton.ejs -->
<!-- 🌟 ATITHI ULTRA-MODERN PREMIUM EMBEDDED INTERACTION BUTTON -->
<div class="ai-itinerary-trigger-zone my-3">
    <button class="btn w-100 py-3 fw-bold border-0 position-relative overflow-hidden atithi-luxury-btn btn-trigger-itinerary" 
            data-listing-id="<%= booking.listing._id %>"
            data-title="<%= booking.listing.title %>"
            data-img="<%= booking.listing.image.url %>"
            data-desc="<%= booking.listing.description %>"
            data-days="<%= computedDays %>">
        
        <!-- Ambient Internal Hover Background Liquid Glow Map Layer -->
        <div class="atithi-btn-liquid-glow"></div>
        
        <!-- Button Text Label Matrix -->
        <span class="atithi-btn-content d-flex align-items-center justify-content-center gap-2">
            <span class="atithi-sparkle-icon">✨</span> 
            <span class="atithi-gradient-text-fill">Plan Your Custom Schedule</span>
        </span>
    </button>
</div>

<!-- 🎨 PLATFORM NATIVE COMPONENT DESIGN EXTENSION STYLES -->
<style>
    .ai-itinerary-trigger-zone {
        perspective: 1000px;
    }
    
    .atithi-luxury-btn {
        background: #ffffff !important;
        border: 1px solid rgba(0, 0, 0, 0.06) !important;
        border-radius: 14px !important;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03), inset 0 1px 0 rgba(255, 255, 255, 0.6) !important;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1) !important;
        cursor: pointer;
    }

    /* Multi-Brand Identity Sublte Text Gradient Pipeline Setup */
    .atithi-gradient-text-fill {
        background: linear-gradient(90deg, #FF9432 0%, #67B636 50%, #00A3E0 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 700;
        font-size: 0.92rem;
        letter-spacing: 0.3px;
    }

    .atithi-sparkle-icon {
        font-size: 1.05rem;
        transition: transform 0.3s ease;
    }

    /* Ambient Liquid Hover Backdrop Glow Blueprint */
    .atithi-btn-liquid-glow {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, rgba(255,148,50,0.04) 0%, rgba(103,182,54,0.04) 50%, rgba(0,163,224,0.04) 100%);
        opacity: 0;
        transition: opacity 0.4s ease;
        z-index: 1;
    }

    .atithi-btn-content {
        position: relative;
        z-index: 2;
    }

    /* Premium Micro-Interactions Hover Mechanics states */
    .atithi-luxury-btn:hover {
        transform: translateY(-3px) scale(1.01);
        border-color: rgba(103, 182, 54, 0.25) !important;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05), inset 0 1px 0 rgba(255, 255, 255, 0.8) !important;
    }

    .atithi-luxury-btn:hover .atithi-btn-liquid-glow {
        opacity: 1;
    }

    .atithi-luxury-btn:hover .atithi-sparkle-icon {
        transform: rotate(15deg) scale(1.15);
    }

    .atithi-luxury-btn:active {
        transform: translateY(-1px) scale(0.99);
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02) !important;
    }
</style>
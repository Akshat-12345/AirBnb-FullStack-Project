<% 
  // Real-time Date Matching Engine
  let todayStr = new Date().toISOString().split("T")[0];
  let checkInStr = new Date(booking.checkInDate).toISOString().split("T")[0];
%>

<% if (booking.paymentStatus === "Paid" && todayStr === checkInStr && (!booking.checkInMedia || !booking.checkInMedia.photos || booking.checkInMedia.photos.length === 0)) { %>
    <div class="checkin-upload-box mt-4 p-4 border border-dashed border-danger rounded-4 bg-light shadow-sm">
        <div class="d-flex align-items-center mb-2">
            <i class="bi bi-camera-reels-fill text-danger me-2 fs-5"></i>
            <h5 class="text-danger mb-0 fw-bold">Check-In Verification Gateway</h5>
        </div>
        <p class="text-muted small mb-3">
            As per host compliance guidelines, please capture and upload exactly **2 Room Photos** and **1 Structural Verification Video** to activate your physical access pass.
        </p>
        
        <form action="/bookings/<%= booking._id %>/checkin-verify" method="POST" enctype="multipart/form-data" class="needs-validation" novalidate>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label small fw-bold text-secondary">📸 Room Snapshot Images (Select Exactly 2):</label>
                    <input type="file" name="checkInPhotos" class="form-control rounded-3" accept="image/*" multiple required>
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-bold text-secondary">🎥 Structural Safety Video (Max 1 Clip):</label>
                    <input type="file" name="checkInVideo" class="form-control rounded-3" accept="video/*" required>
                </div>
            </div>
            <button type="submit" class="btn btn-danger px-4 mt-3 rounded-3 fw-bold btn-sm shadow-sm">
                <i class="bi bi-cloud-arrow-up-fill me-1"></i> Submit Verification Assets
            </button>
        </form>
    </div>
<% } else if (booking.checkInMedia && booking.checkInMedia.photos && booking.checkInMedia.photos.length > 0) { %>
    <div class="mt-3 p-3 border border-success rounded-4 bg-success bg-opacity-10 d-flex align-items-center gap-2 shadow-sm">
        <i class="bi bi-shield-check text-success fs-5"></i>
        <p class="text-success small mb-0 fw-bold">Check-In Authentication Matrix secured and synced with Host Ledger.</p>
    </div>
<% } %>
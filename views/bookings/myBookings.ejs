<%= layout("/layouts/boiler_plate.ejs") %>

<style>
  :root {
    /* Atithi Immersive Brand Identity System */
    --atithi-orange: #FF9432;
    --atithi-green: #67B636;
    --atithi-blue: #00A3E0;
    --atithi-gradient: linear-gradient(135deg, #FF9432 0%, #67B636 50%, #00A3E0 100%);
    --airbnb-red: #FF385C;
    --text-slate-dark: #1E293B;
    --text-slate-muted: #64748B;
    --font-premium-stack: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  body, html {
    font-family: var(--font-premium-stack);
    -webkit-font-smoothing: antialiased;
    letter-spacing: -0.2px;
    background-color: #FAFAFA !important; 
  }

  /* === 🚀 DYNAMIC CHROMIUM ENGINE CUSTOM SCROLLBARS === */
  ::-webkit-scrollbar {
    width: 8px;
    height: 6px;
    background-color: rgba(0, 0, 0, 0.01);
  }
  ::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.02);
    border-radius: 100px;
  }
  ::-webkit-scrollbar-thumb {
    background: linear-gradient(180deg, var(--atithi-orange) 0%, var(--atithi-green) 50%, var(--atithi-blue) 100%);
    border-radius: 100px;
  }

  /* === 🌟 PREMIUM USER HERO BANNER SLIDESHOW WORKSPACE === */
  .dashboard-user-banner {
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    padding: 80px 4% 100px 4%;
    box-sizing: border-box;
    margin-bottom: 40px;
    overflow: hidden;
    background-color: #0F172A; 
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }

  .banner-slide-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    z-index: 1;
    transition: opacity 1.5s cubic-bezier(0.4, 0, 0.2, 1); 
  }
  
  .banner-slide-bg.slide-active {
    opacity: 0.35;
  }

  .banner-mask-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.5) 0%, rgba(15, 23, 42, 0.8) 100%);
    z-index: 2;
  }

  .banner-content-cluster {
    position: relative;
    z-index: 3; 
  }

  .banner-voyager-title {
    color: #ffffff !important;
    font-weight: 800;
    font-size: 36px;
    letter-spacing: -0.8px;
  }
  
  .banner-voyager-desc {
    color: rgba(255, 255, 255, 0.8) !important;
    font-size: 15px;
    font-weight: 400;
    max-width: 800px;
  }

  /* === 🌟 HIGH-FIDELITY BENTO INTEL METRICS CARDS === */
  .metric-card { 
    border-radius: 24px; 
    position: relative; 
    overflow: hidden; 
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.5) !important;
    padding: 28px 24px;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1); 
  }
  .metric-card:hover { 
    transform: translateY(-5px); 
    background: #ffffff;
    box-shadow: 0 20px 40px rgba(15, 23, 42, 0.15) !important; 
  }
  
  .premium-badge { 
    background: rgba(15, 23, 42, 0.95) !important; 
    border: 1px solid rgba(255, 255, 255, 0.08) !important;
  }
  .premium-badge::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: var(--atithi-gradient);
  }

  .metric-headline-tag {
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.6px;
    margin-bottom: 8px !important;
  }

  .metric-sub-context-text {
    font-size: 12px;
    color: var(--text-slate-muted);
    font-weight: 400;
    line-height: 1.4;
    margin-top: 10px;
    margin-bottom: 0;
  }
  .premium-badge .metric-sub-context-text {
    color: rgba(255, 255, 255, 0.5);
  }

  /* === 🌟 LUXURY COMPACT ACCOMMODATION CARDS === */
  .dashboard-lower-workspace {
    width: 100%;
    padding: 10px 0 60px 0;
  }

  .atithi-stay-card {
    background: #ffffff !important;
    border: 1px solid rgba(0, 0, 0, 0.05) !important;
    border-radius: 24px !important;
    padding: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02) !important;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .atithi-stay-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 35px rgba(0, 0, 0, 0.06) !important;
    border-color: rgba(0, 0, 0, 0.08) !important;
  }

  .image-wrapper-node { 
    position: relative; 
    overflow: hidden; 
    border-radius: 16px;
    aspect-ratio: 4 / 3;
    background-color: #f1f5f9;
  }

  .image-wrapper-node img {
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .atithi-stay-card:hover .image-wrapper-node img {
    transform: scale(1.04);
  }
  
  .badge-phase-custom { 
    font-size: 10px; 
    font-weight: 700; 
    border-radius: 8px; 
    padding: 6px 12px; 
    letter-spacing: 0.5px; 
  }

  .split-ledger-box { 
    background-color: #F8FAFC; 
    border: 1px solid rgba(0, 0, 0, 0.04); 
    border-radius: 16px; 
    padding: 16px; 
  }
  .participant-node { 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
    padding: 8px 0; 
    border-bottom: 1px solid rgba(0, 0, 0, 0.04); 
  }
  .participant-node:last-child { 
    border-bottom: none; 
  }

  .badge-settled { 
    background-color: rgba(103, 182, 54, 0.08); 
    color: var(--atithi-green); 
    font-size: 11px; 
    font-weight: 700; 
    padding: 4px 10px; 
    border-radius: 8px; 
    border: 1px solid rgba(103, 182, 54, 0.12); 
  }
  .badge-waiting { 
    background-color: rgba(255, 148, 50, 0.08); 
    color: var(--atithi-orange); 
    font-size: 11px; 
    font-weight: 700; 
    padding: 4px 10px; 
    border-radius: 8px; 
    border: 1px solid rgba(255, 148, 50, 0.12); 
  }
  
  .history-card-wrapper { 
    background: #ffffff !important;
    border: 1px solid rgba(0, 0, 0, 0.04) !important;
    border-radius: 20px !important;
    padding: 20px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.01) !important;
    transition: all 0.25s ease;
  }
  .history-card-wrapper:hover {
    border-color: rgba(0, 0, 0, 0.08) !important;
    box-shadow: 0 12px 25px rgba(0, 0, 0, 0.04) !important;
  }
  
  .history-detail-plate { 
    background-color: #F8FAFC; 
    border-radius: 12px; 
    padding: 10px 14px; 
    border: 1px solid rgba(0, 0, 0, 0.02);
  }
</style>

<div class="dashboard-user-banner">
  <div class="banner-slide-bg slide-active" style="background-image: url('https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?q=80&w=2000&auto=format&fit=crop');"></div>
  <div class="banner-slide-bg" style="background-image: url('https://images.unsplash.com/photo-1605774337664-7a846e9cdf17?q=80&w=1400&auto=format&fit=crop');"></div>
  <div class="banner-slide-bg" style="background-image: url('https://images.unsplash.com/photo-1505843513577-22bb7d21e455?q=80&w=1400&auto=format&fit=crop');"></div>
  <div class="banner-slide-bg" style="background-image: url('https://images.unsplash.com/photo-1706808849780-7a04fbac83ef?q=80&w=1400&auto=format&fit=crop');"></div>

  <div class="banner-mask-overlay"></div>

  <div class="banner-content-cluster">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
      <div>
        <h2 class="banner-voyager-title mb-2">Welcome Back, Voyager!</h2>
        <p class="banner-voyager-desc mb-0">Track your real-time reservations, travel analytics ledger, and architecture pipelines seamlessly.</p>
      </div>
      <a href="/listings" class="btn btn-light px-4 py-2 rounded-pill fw-bold text-dark border-0 shadow transition-all" style="font-size: 13px;"><i class="bi bi-compass me-2" style="color: var(--atithi-orange);"></i>Explore New Places</a>
    </div>

    <div class="row g-4 mt-2">
      <div class="col-6 col-md-3">
        <div class="card metric-card border-0 h-100">
          <p class="text-slate-muted text-uppercase small fw-bold font-monospace metric-headline-tag"><i class="bi bi-compass me-1.5" style="color: var(--atithi-orange);"></i>Total index Trips</p>
          <h3 class="fw-bold mb-0 text-dark display-6" style="letter-spacing: -1px;"><%= typeof metrics !== 'undefined' && metrics.totalTrips ? metrics.totalTrips : 0 %></h3>
          <p class="metric-sub-context-text">Checked-out properties processed cleanly under your active profile ledger.</p>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card metric-card border-0 h-100">
          <p class="text-slate-muted text-uppercase small fw-bold font-monospace metric-headline-tag"><i class="bi bi-moon-stars me-1.5" style="color: var(--atithi-green);"></i>Nights Camped</p>
          <h3 class="fw-bold mb-0 text-dark display-6" style="letter-spacing: -1px;"><%= typeof metrics !== 'undefined' && metrics.totalNights ? metrics.totalNights : 0 %> <span class="fs-6 text-muted fw-semibold">Nights</span></h3>
          <p class="metric-sub-context-text">Accumulated night cycles cleared safely across verified locations global index.</p>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card metric-card premium-badge p-4 h-100">
          <p class="text-white-50 text-uppercase small fw-bold font-monospace metric-headline-tag"><i class="bi bi-currency-rupee me-1" style="color: var(--atithi-orange);"></i>Invested Value</p>
          <h3 class="fw-bold mb-0 text-white display-6" style="letter-spacing: -1px;">₹<%= typeof metrics !== 'undefined' && metrics.totalSpent ? metrics.totalSpent.toLocaleString("en-IN") : 0 %></h3>
          <p class="metric-sub-context-text">Net operational financial capital settled across dynamic booking systems.</p>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card metric-card shadow border-0 bg-dark text-white h-100">
          <p class="text-white-50 text-uppercase small fw-bold font-monospace metric-headline-tag"><i class="bi bi-hourglass-split me-1.5" style="color: var(--atithi-blue);"></i>Upcoming Trips</p>
          <h3 class="fw-bold mb-0 text-white display-6" style="letter-spacing: -1px;"><%= typeof metrics !== 'undefined' && metrics.upcomingTripsCount ? metrics.upcomingTripsCount : 0 %> <span class="badge bg-danger ms-2 font-monospace" style="font-size: 10px !important; padding: 4px 8px; vertical-align: middle;">LIVE FEED</span></h3>
          <p class="metric-sub-context-text" style="color: rgba(255,255,255,0.55);">Active pipelines and scheduling blocks queued inside the execution core engine.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="container-fluid px-md-5 dashboard-lower-workspace">

  <div class="border-bottom pb-3 mb-4 d-flex align-items-center justify-content-between" style="border-bottom: 1px solid rgba(0,0,0,0.06) !important;">
    <h4 class="fw-bold text-dark mb-0" style="font-size: 20px; letter-spacing: -0.4px;"><i class="bi bi-calendar2-range text-danger me-2"></i>Active Accommodations Queue</h4>
    <span class="badge bg-white text-dark border rounded-pill font-monospace px-3 py-2 shadow-sm" style="font-size: 11px; font-weight: 600;"><%= bookings.length %> Stays Running</span>
  </div>

  <% if(bookings.length === 0) { %>
    <div class="p-5 text-center bg-white rounded-4 border mb-5" style="border-color: rgba(0,0,0,0.06) !important; border-radius: 24px !important;">
      <i class="bi bi-bookmark-x display-5 text-muted d-block mb-3"></i>
      <h5 class="text-secondary fw-bold">No running reservations or active holds found.</h5>
      <p class="text-muted small mb-0 fw-medium">Your current operations ledger is clean. Initiate listings to start verification cycles.</p>
    </div>
  <% } else { %>
    <div class="row mb-5 g-4">
      <% for(let booking of bookings) { %>
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 atithi-stay-card">
            
            <div class="image-wrapper-node position-relative overflow-hidden mb-3">
              <% if (booking && booking.listing && booking.listing.image) { %>
                <% if (Array.isArray(booking.listing.image) && booking.listing.image.length > 0) { %>
                  <img src="<%= booking.listing.image[0].url %>" class="w-100 h-100" alt="Property asset" style="object-fit: cover;">
                <% } else if (booking.listing.image.url) { %>
                  <img src="<%= booking.listing.image.url %>" class="w-100 h-100" alt="Property asset" style="object-fit: cover;">
                <% } else { %>
                  <img src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80" class="w-100 h-100" alt="Property placeholder" style="object-fit: cover;">
                <% } %>
              <% } else { %>
                <img src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80" class="w-100 h-100" alt="Property placeholder" style="object-fit: cover;">
              <% } %>

              <span class="position-absolute top-0 end-0 m-3 badge bg-dark text-uppercase font-monospace px-2.5 py-1.5" style="z-index: 5; font-size: 9px; font-weight: 700; border-radius: 6px; letter-spacing: 0.5px; opacity: 0.95;">
                <%= booking ? booking.bookingPhase : 'Active' %>
              </span>
            </div>

            <div class="card-body p-0 d-flex flex-column justify-content-between">
              <div>
                <h5 class="fw-bold text-truncate text-dark mb-1" style="font-size: 16px;"><%= (booking && booking.listing) ? booking.listing.title : 'Atithi Premium Accommodations' %></h5>
                <p class="text-muted mb-3 small fw-medium"><i class="bi bi-geo-alt-fill me-1 text-danger"></i><%= (booking && booking.listing) ? `${booking.listing.location}, ${booking.listing.country}` : 'Verified Gateway' %></p>
                
                <div class="p-3 rounded-3 mb-3" style="background-color: #F8FAFC !important; border: 1px solid rgba(0,0,0,0.02);">
                  <div class="d-flex justify-content-between mb-1 small text-muted">
                    <span class="fw-medium">Check-In Slot:</span>
                    <span class="text-dark fw-bold"><%= new Date(booking.checkInDate).toLocaleDateString("en-IN", {month: 'short', day: 'numeric', year: 'numeric'}) %></span>
                  </div>
                  <div class="d-flex justify-content-between small text-muted">
                    <span class="fw-medium">Check-Out Slot:</span>
                    <span class="text-dark fw-bold"><%= new Date(booking.checkOutDate).toLocaleDateString("en-IN", {month: 'short', day: 'numeric', year: 'numeric'}) %></span>
                  </div>
                </div>

                <% 
                  let timeDiff = new Date(booking.checkOutDate).getTime() - new Date(booking.checkInDate).getTime();
                  let computedDays = Math.ceil(timeDiff / (1000 * 3600 * 24));
                  if(!computedDays || computedDays <= 0) computedDays = 1; 
                %>

                <!-- 🔗 LINKED RE-CRAFT ENGINE WORKSPACE BUTTON (LOCAL DIRECTORY PATH FIXED) -->
<%- include("./includes/itineraryButton.ejs", { booking: booking, computedDays: computedDays }) %>

                <% if(booking.isSplitBooking && booking.splitParticipants) { %>
                  <div class="split-ledger-box mb-3 mt-3">
                    <p class="text-muted small fw-bold mb-2 font-monospace text-uppercase" style="font-size: 10px; letter-spacing: 0.4px;"><i class="bi bi-people-fill text-danger me-1"></i> Co-Travelers Split Matrix</p>
                    <div class="participant-node">
                      <span class="small text-dark fw-bold text-truncate" style="max-width: 160px;">
                        <%= booking.user ? booking.user.username : "Main User" %> (Primary Booker)
                      </span>
                      <span class="badge-settled">Paid</span>
                    </div>
                    <% for(let friend of booking.splitParticipants) { %>
                      <div class="participant-node">
                        <span class="small text-muted text-truncate fw-medium" style="max-width: 130px;" title="<%= friend.email %>"><%= friend.email %></span>
                        <div class="d-flex align-items-center gap-1">
                          <span class="small fw-bold text-dark me-2" style="font-size: 11.5px;">₹<%= friend.shareAmount %></span>
                          <% if(friend.hasPaid) { %>
                            <span class="badge-settled"><i class="bi bi-check"></i> Paid</span>
                          <% } else { %>
                            <span class="badge-waiting me-1">Pending</span>
                            <button class="btn btn-sm btn-danger py-1 px-2 btn-clear-share font-monospace fw-bold text-uppercase" style="font-size: 9px; border-radius: 6px;" data-booking-id="<%= booking._id %>" data-friend-email="<%= friend.email %>">Pay</button>
                          <% } %>
                        </div>
                      </div>
                    <% } %>
                  </div>
                <% } %>

                <div class="d-flex flex-column gap-2 mt-3">
                  <%- include("includes/checkInForm.ejs", { booking: booking }) %>
                  <%- include("includes/checkOutForm.ejs", { booking: booking }) %>
                </div>

                <% if (booking.dispute && booking.dispute.isDamaged) { %>
                  <div class="card mt-3 shadow-sm bg-white border-0" style="border-radius: 16px; overflow: hidden; border: 1px solid rgba(255, 56, 92, 0.2) !important;">
                    <div class="card-header text-white small fw-bold py-2 font-monospace" style="background-color: var(--airbnb-red) !important; letter-spacing: 0.3px;"><i class="bi bi-exclamation-octagon me-1"></i> DAMAGE LIABILITY STATEMENT</div>
                    <div class="card-body p-3 text-start">
                      <p class="mb-1 text-dark small fw-medium"><b>Reason Log:</b> <%= booking.dispute.fineReason %></p>
                      <p class="mb-2 text-secondary small fw-medium"><b>Fine Balance Outstanding:</b> <span class="text-danger fw-bold fs-6">₹<%= booking.dispute.fineAmount %></span></p>

                      <% if (!booking.dispute.isFinePaid) { %>
                        <% if (currUser && currUser._id && booking.user && (currUser._id.equals(booking.user._id) || currUser._id.equals(booking.user))) { %>
                          <button class="btn btn-sm btn-danger w-100 fw-bold py-2 text-uppercase btn-settle-fine font-monospace" style="font-size: 11px; border-radius: 8px; background-color: var(--airbnb-red); border: none;" data-booking-id="<%= booking._id %>" data-fine-order-id="<%= booking.dispute.fineRazorpayOrderId %>" data-fine-amount="<%= booking.dispute.fineAmount %>">
                            <i class="bi bi-credit-card-2-back-fill me-1"></i> Settle Asset fine Balance
                          </button>
                        <% } else { %>
                          <div class="alert alert-secondary border-0 p-2 mb-0 text-center text-muted small fw-medium" style="font-size: 11px; background-color: #F8FAFC; border: 1px solid rgba(0,0,0,0.04) !important; border-radius: 8px;">
                            <i class="bi bi-info-circle-fill me-1"></i> Awaiting transactional architecture clearance from primary user.
                          </div>
                        <% } %>
                      <% } %>
                    </div>
                  </div>
                <% } %>
              </div>

              <div class="d-flex justify-content-between align-items-center mt-3 pt-2" style="border-top: 1px solid rgba(0,0,0,0.04);">
                <span class="badge bg-light <%= booking.paymentStatus === 'Paid' ? 'text-success border-success' : 'text-warning border-warning' %> border px-3 py-1.5 fw-bold" style="border-radius: 8px; font-size: 11px;">
                  <i class="bi <%= booking.paymentStatus === 'Paid' ? 'bi-check-circle-fill' : 'bi-clock-history' %> me-1"></i><%= booking.paymentStatus %>
                </span>
                <h5 class="fw-bold text-dark mb-0 fs-5">₹<%= booking.totalPrice ? booking.totalPrice.toLocaleString("en-IN") : '0' %></h5>
              </div>
            </div>

          </div>
        </div>
      <% } %>
    </div>
  <% } %>

  <div class="border-bottom pb-3 mb-4 mt-5 d-flex align-items-center justify-content-between" style="border-bottom: 1px solid rgba(0,0,0,0.06) !important;">
    <h4 class="fw-bold text-secondary mb-0" style="font-size: 20px; letter-spacing: -0.4px;"><i class="bi bi-archive-fill text-muted me-2"></i>Past Archives & Ledger History</h4>
    <span class="badge bg-light text-secondary border rounded-pill font-monospace px-3 py-1.5 fw-bold" style="font-size: 11px;"><%= pastBookings ? pastBookings.length : 0 %> Logs Compiled</span>
  </div>

  <% if(!pastBookings || pastBookings.length === 0) { %>
    <div class="p-4 text-center text-muted small bg-white rounded-4 border" style="border-style: dashed !important; border-radius: 20px !important;">
      <i class="bi bi-folder-symlink display-6 mb-2 d-block text-muted"></i> No historical archive logs compiled yet inside profile repository.
    </div>
  <% } else { %>
    <div class="row g-4">
      <% for(let past of pastBookings) { %>
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 border-0 history-card-wrapper">
            <div class="card-body p-0 d-flex flex-column justify-content-between">
              <div>
                <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                  <h6 class="fw-bold text-truncate mb-0 fs-6" style="color: var(--text-slate-dark); max-width: 180px;">
                    <%= (past.listing) ? past.listing.title : 'Historical Stay Document' %>
                  </h6>
                  
                  <% if (past.paymentStatus === 'Refunded') { %>
                    <span class="badge badge-phase-custom bg-light text-primary border border-primary">REFUNDED</span>
                  <% } else if (past.paymentStatus === 'Cancelled') { %>
                    <span class="badge badge-phase-custom bg-light text-secondary border border-secondary">CANCELLED</span>
                  <% } else if (past.bookingPhase !== 'CheckedOut') { %>
                    <span class="badge badge-phase-custom bg-light text-warning border border-warning">ELAPSED LOG</span>
                  <% } else { %>
                    <span class="badge badge-phase-custom bg-light text-success border border-success">COMPLETED</span>
                  <% } %>
                </div>
                
                <p class="text-muted small mb-3 fw-medium">
                  <i class="bi bi-geo-alt me-1"></i>
                  <%= (past.listing) ? `${past.listing.location}, ${past.listing.country}` : 'Archived Node Repository' %>
                </p>
                
                <div class="history-detail-plate small text-muted mb-2">
                  <div class="d-flex justify-content-between fw-medium">
                    <span>Duration Track Matrix:</span>
                    <span class="text-dark fw-bold"><%= new Date(past.checkInDate).toLocaleDateString("en-IN", {month: '2-digit', day: '2-digit'}) %> to <%= new Date(past.checkOutDate).toLocaleDateString("en-IN", {month: '2-digit', day: '2-digit', year: '2-digit'}) %></span>
                  </div>
                </div>

                <% if (past.dispute && past.dispute.isDamaged && past.dispute.isFinePaid) { %>
                  <div class="alert alert-success border-0 py-1.5 px-3 mb-0 text-center text-success fw-bold" style="font-size: 11px; background-color: rgba(103, 182, 54, 0.06); border-radius: 8px;">
                    <i class="bi bi-patch-check-fill me-1"></i> Liability Settlement Verified (₹<%= past.dispute.fineAmount %>)
                  </div>
                <% } %>
              </div>

              <div class="d-flex justify-content-between align-items-center mt-3 pt-2 small font-monospace" style="border-top: 1px solid rgba(0,0,0,0.04);">
                <span class="text-muted fw-semibold">Ledger Clear State:</span>
                <span class="text-dark fw-bold fs-6">₹<%= past.totalPrice ? past.totalPrice.toLocaleString("en-IN") : 0 %></span>
              </div>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  <% } %>

</div>

<%- include("includes/itineraryModal.ejs") %>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    
    // === 🚀 CRUCIAL INTERACTIVE AUTO-SLIDESHOW LOOP ===
    const slides = document.querySelectorAll('.banner-slide-bg');
    let currentSlideIndex = 0;
    
    function rotateBannerSlides() {
      if(slides.length > 0) {
        slides[currentSlideIndex].classList.remove('slide-active');
        currentSlideIndex = (currentSlideIndex + 1) % slides.length;
        slides[currentSlideIndex].classList.add('slide-active');
      }
    }
    setInterval(rotateBannerSlides, 5000);

    // 1. Co-Traveler Split Payment Transaction Engine 
    const clearShareBtns = document.querySelectorAll(".btn-clear-share");
    clearShareBtns.forEach(btn => {
      btn.addEventListener("click", async function(e) {
        e.preventDefault();
        const bookingId = this.dataset.bookingId;
        const participantEmail = this.dataset.friendEmail;
        this.innerHTML = `<span class="spinner-border spinner-border-sm" style="width:10px; height:10px;"></span>`;
        this.disabled = true;

        const response = await fetch("/bookings/initiate-share-payment", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ bookingId, participantEmail })
        });

        const dataRes = await response.json();
        if (!dataRes.success) {
          alert("Error: " + dataRes.message);
          window.location.reload();
          return;
        }

        const options = {
          "key": dataRes.key_id,
          "amount": dataRes.rzpOrder.amount,
          "currency": dataRes.rzpOrder.currency,
          "name": "Co-Traveler Settlement",
          "description": `Clearing share segment for ${participantEmail}`,
          "order_id": dataRes.rzpOrder.id,
          "handler": async function (rzpResponse) {
            const verifyRes = await fetch("/bookings/verify-share-payment", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                razorpay_order_id: rzpResponse.razorpay_order_id,
                razorpay_payment_id: rzpResponse.razorpay_payment_id,
                razorpay_signature: rzpResponse.razorpay_signature,
                bookingId: bookingId
              })
            });

            const verifyData = await verifyRes.json();
            if (verifyData.success) {
              window.location.reload();
            } else {
              alert("Verification failed at transaction endpoint.");
              window.location.reload();
            }
          },
          "theme": { "color": "#ff385c" }
        };
        const rzp = new Razorpay(options);
        rzp.open();
        this.innerHTML = "Pay";
        this.disabled = false;
      });
    });

    // 2. Primary Booker Fine Settlement Engine Binder
    const clearFineBtns = document.querySelectorAll(".btn-settle-fine");
    clearFineBtns.forEach(btn => {
      btn.addEventListener("click", function(e) {
        e.preventDefault();
        const bookingId = this.dataset.bookingId;
        const fineOrderId = this.dataset.fineOrderId;
        const fineAmount = this.dataset.fineAmount;

        const options = {
          "key": "<%= typeof razorpayKeyId !== 'undefined' ? razorpayKeyId : '' %>", 
          "amount": fineAmount * 100,
          "currency": "INR",
          "name": "Property Damage Fine Settlement",
          "description": "Compensatory damage asset liability closure",
          "order_id": fineOrderId,
          "handler": async function (rzpResponse) {
            const verifyRes = await fetch("/bookings/verify-fine-payment", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                razorpay_order_id: rzpResponse.razorpay_order_id,
                razorpay_payment_id: rzpResponse.razorpay_payment_id,
                razorpay_signature: rzpResponse.razorpay_signature,
                bookingId: bookingId
              })
            });

            const verifyData = await verifyRes.json();
            if (verifyData.success) {
              window.location.reload();
            } else {
              alert("Fine transaction signature authentication verification failed.");
              window.location.reload();
            }
          },
          "theme": { "color": "#ff385c" }
        };
        const rzp = new Razorpay(options);
        rzp.open();
      });
    });

  });
</script>
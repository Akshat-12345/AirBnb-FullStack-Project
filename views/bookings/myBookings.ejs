<% layout("/layouts/boiler_plate.ejs") %>
<style>
  .metric-card { transition: transform 0.2s; border-radius: 16px; }
  .metric-card:hover { transform: translateY(-4px); }
  .premium-badge { background: linear-gradient(135deg, #ff385c 0%, #bd1e59 100%); color: #fff; border: none; }
  .card-img-gradient { position: relative; }
  .card-img-gradient::after { content: ""; position: absolute; bottom: 0; left: 0; right: 0; height: 40%; background: linear-gradient(to top, rgba(0,0,0,0.6), transparent); }
</style>
<div class="container mt-5 mb-5">
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
    <div>
      <h2 class="fw-bold tracking-tight">Welcome Back, Voyager!</h2>
      <p class="text-muted mb-0">Track your reservations, travel expenditure, and future destinations.</p>
    </div>
    <a href="/listings" class="btn btn-outline-dark px-4 py-2 mt-2" style="border-radius: 20px;"><i class="bi bi-compass me-2"></i>Explore More</a>
  </div>

  <div class="row mb-5">
    <div class="col-6 col-md-3 mb-3">
      <div class="card metric-card border-0 shadow-sm p-3 bg-white text-dark">
        <p class="text-muted text-uppercase small fw-bold mb-1">Total Trips</p>
        <h3 class="fw-bold mb-0"><%= metrics.totalTrips %></h3>
      </div>
    </div>
    <div class="col-6 col-md-3 mb-3">
      <div class="card metric-card border-0 shadow-sm p-3 bg-white text-dark">
        <p class="text-muted text-uppercase small fw-bold mb-1">Nights Camped</p>
        <h3 class="fw-bold mb-0"><%= metrics.totalNights %> <span class="fs-6 text-muted font-monospace">Nights</span></h3>
      </div>
    </div>
    <div class="col-6 col-md-3 mb-3">
      <div class="card metric-card border-0 shadow-sm p-3 premium-badge shadow">
        <p class="text-white-50 text-uppercase small fw-bold mb-1">Invested Value</p>
        <h3 class="fw-bold mb-0">&#8377;<%= metrics.totalSpent.toLocaleString("en-IN") %></h3>
      </div>
    </div>
    <div class="col-6 col-md-3 mb-3">
      <div class="card metric-card border-0 shadow-sm p-3 bg-dark text-white">
        <p class="text-white-50 text-uppercase small fw-bold mb-1">Upcoming Trips</p>
        <h3 class="fw-bold mb-0"><%= metrics.upcomingTripsCount %> <span class="badge bg-danger ms-2 font-monospace">Live</span></h3>
      </div>
    </div>
  </div>

  <h3 class="fw-bold mb-4">Your Booking Catalog</h3>
  <% if(bookings.length === 0) { %>
    <div class="p-5 text-center bg-white rounded shadow-sm border">
      <i class="bi bi-suit-heart display-4 text-muted mb-3"></i>
      <h4>No Accommodations Found!</h4>
      <p class="text-muted">Looks like you haven't booked an active property yet.</p>
    </div>
  <% } else { %>
    <div class="row">
      <% for(let booking of bookings) { %>
        <% if(booking.listing) { %>
          <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm border-0 metric-card" style="border-radius: 16px; overflow: hidden; background: #fff;">
              <div class="card-img-gradient">
                <img src="<%= booking.listing.image.url %>" class="card-img-top" alt="property" style="height: 220px; object-fit: cover;">
              </div>
              <div class="card-body p-4">
                <h5 class="fw-bold text-truncate mb-2"><%= booking.listing.title %></h5>
                <p class="text-muted mb-3 small"><i class="bi bi-geo-alt-fill me-2 text-danger"></i><%= booking.listing.location %>, <%= booking.listing.country %></p>
                
                <div class="bg-light p-3 rounded-3 mb-3">
                  <div class="d-flex justify-content-between mb-1 small text-muted">
                    <span>Check-in:</span>
                    <span class="text-dark fw-bold"><%= new Date(booking.checkInDate).toLocaleDateString("en-US", {month: 'short', day: 'numeric', year: 'numeric'}) %></span>
                  </div>
                  <div class="d-flex justify-content-between small text-muted">
                    <span>Check-out:</span>
                    <span class="text-dark fw-bold"><%= new Date(booking.checkOutDate).toLocaleDateString("en-US", {month: 'short', day: 'numeric', year: 'numeric'}) %></span>
                  </div>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                  <span class="badge bg-light text-success border border-success px-3 py-2" style="border-radius: 12px;"><i class="bi bi-check-circle-fill me-1"></i><%= booking.paymentStatus %></span>
                  <h5 class="fw-bold text-danger mb-0">&#8377;<%= booking.totalPrice.toLocaleString("en-IN") %></h5>
                </div>
              </div>
            </div>
          </div>
        <% } %>
      <% } %>
    </div>
  <% } %>
</div>
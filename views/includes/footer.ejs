<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
  :root {
    /* Atithi Signature Creative Colors Blueprint */
    --brand-orange: #FF9432;
    --brand-green: #67B636;
    --brand-blue: #00A3E0;
    
    --matrix-dark: #0f172a;       /* 🚀 FIXED: Exact dark backdrop matching image_6350ff.png */
    --bg-sub-dark: #1e293b;       /* Balanced slate interior layers for fields */
    --text-pure: #ffffff;         /* Premium high-end text headers */
    --text-muted-gray: #94a3b8;   /* Sleek clean grey text parameters */
    --glass-border: rgba(255, 255, 255, 0.08);
    --font-premium-stack: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto, sans-serif;
  }

  /* === 🌌 ABSOLUTE SPACE METALLIC FOOTER CONSOLE === */
  .footer-clean-engine {
    background-color: var(--matrix-dark) !important;
    border-top: 1px solid var(--glass-border);
    padding-top: 65px;
    padding-bottom: 35px;
    position: relative;
    font-family: var(--font-premium-stack);
    -webkit-font-smoothing: antialiased;
    box-shadow: 0 -8px 32px rgba(0, 0, 0, 0.2);
  }

  /* 🚀 TOP CEILING GLOW STRIP: Matches navbar dynamic ceiling pixel-for-pixel */
  .footer-clean-engine::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3.5px;
    background: linear-gradient(90deg, var(--brand-orange) 0%, var(--brand-green) 50%, var(--brand-blue) 100%);
    z-index: 10;
  }

  .footer-brand-block {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-right: 30px; 
  }
  
  .footer-logo-img {
    height: 36px;
    object-fit: contain;
    filter: drop-shadow(0 0 10px rgba(255, 148, 50, 0.25));
  }

  .footer-logo-text {
    font-weight: 800;
    font-size: 28px;
    letter-spacing: -0.5px;
    background: linear-gradient(135deg, var(--brand-orange) 0%, var(--brand-green) 50%, var(--brand-blue) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: inline-block;
  }
  
  .footer-brand-desc {
    font-size: 14px;
    color: var(--text-muted-gray);
    line-height: 1.6;
    font-weight: 400;
    margin-bottom: 8px;
  }

  /* === 🔍 PREMIUM INTEGRATED INPUT DOCK === */
  .footer-newsletter-form {
    display: flex;
    gap: 10px;
    max-width: 320px;
    margin-top: 4px;
    position: relative;
  }
  .newsletter-input {
    flex: 1;
    background: var(--bg-sub-dark);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 11px 14px;
    font-size: 13.5px;
    font-weight: 500;
    color: var(--text-pure);
    outline: none;
    transition: all 0.25s ease;
  }
  .newsletter-input:focus {
    border-color: var(--brand-orange);
    box-shadow: 0 0 0 4px rgba(255, 148, 50, 0.15);
  }
  .newsletter-submit-btn {
    background: linear-gradient(135deg, var(--brand-orange), #ff5a36);
    color: white;
    border: none;
    border-radius: 12px;
    padding: 11px 18px;
    font-size: 13.5px;
    font-weight: 700;
    transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    cursor: pointer;
    box-shadow: 0 4px 12px rgba(255, 90, 54, 0.25);
  }
  .newsletter-submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(255, 90, 54, 0.4);
  }

  .footer-col-deck h6 {
    font-size: 14px;
    font-weight: 700;
    color: var(--text-pure) !important; /* Bold solid white text header categories */
    margin-bottom: 22px;
    letter-spacing: 0.3px;
    display: inline-block;
  }

  .footer-col-deck ul {
    list-style: none;
    padding-left: 0;
    margin-bottom: 0;
  }

  .footer-col-deck ul li {
    margin-bottom: 12px;
  }

  .footer-col-deck ul li a {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-muted-gray) !important;
    text-decoration: none;
    display: inline-block;
    transition: all 0.2s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  /* 🚀 ADDED MICRO ANIMATIONS: Organic kinetic lift on focus */
  .footer-col-deck ul li a:hover {
    transform: translateX(4px); 
    color: var(--text-pure) !important;
  }
  
  /* === 👤 MINIMALIST BOTTOM CREDITS DASHBOARD === */
  .footer-clean-dock {
    border-top: 1px solid var(--glass-border);
    margin-top: 45px;
    padding-top: 26px;
    font-size: 14px;
  }

  .copyright-pill {
    font-weight: 500;
    color: var(--text-muted-gray);
  }

  .dock-links-array {
    display: flex;
    gap: 20px;
  }

  .dock-links-array a {
    color: var(--text-muted-gray);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }
  .dock-links-array a:hover {
    color: var(--text-pure);
  }

  .dock-social-deck {
    display: flex;
    gap: 16px;
  }

  .social-minimal-item {
    font-size: 18px;
    color: var(--text-muted-gray);
    text-decoration: none;
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    display: inline-block;
  }

  .social-minimal-item:hover {
    transform: scale(1.2) translateY(-2px);
    color: var(--brand-orange); /* Glowing pop to primary branding accent color */
  }
</style>

<footer class="footer footer-clean-engine">
  <div class="container">
    <div class="row">
      <div class="col-12 col-lg-4 mb-5 mb-lg-0 footer-brand-block">
        <div class="d-flex align-items-center gap-2">
          <img src="/images/airbnb.png" alt="Atithi Logo" class="footer-logo-img">
          <span class="footer-logo-text">Atithi</span>
        </div>
        <p class="footer-brand-desc">
          Discover localized stay paradigms and premium group experiences. Stay integrated, travel unified.
        </p>
        
        <form class="footer-newsletter-form" id="newsletterForm">
          <input type="email" class="newsletter-input" id="newsletterEmail" placeholder="Subscribe to our updates" required>
          <button class="newsletter-submit-btn" type="submit" id="newsletterBtn">Join</button>
        </form>
      </div>

      <div class="col-6 col-md-3 col-lg-2 mb-4 footer-col-deck">
        <h6>About</h6>
        <ul>
          <li><a href="#">How Atithi Works</a></li>
          <li><a href="#">Newsroom Logs</a></li>
          <li><a href="#">Investors Capital</a></li>
          <li><a href="#">Atithi Plus</a></li>
        </ul>
      </div>

      <div class="col-6 col-md-3 col-lg-2 mb-4 footer-col-deck">
        <h6>Community</h6>
        <ul>
          <li><a href="#">Diversity</a></li>
          <li><a href="#">Accessibility</a></li>
          <li><a href="#">Invite Associates</a></li>
        </ul>
      </div>

      <div class="col-6 col-md-3 col-lg-2 mb-4 footer-col-deck">
        <h6>Hosting</h6>
        <ul>
          <li><a href="/listings/new">Try Hosting</a></li>
          <li><a href="#">AirCover</a></li>
          <li><a href="#">Resources</a></li>
        </ul>
      </div>

      <div class="col-6 col-md-3 col-lg-2 mb-4 footer-col-deck">
        <h6>Support</h6>
        <ul>
          <li><a href="#">Help Centre</a></li>
          <li><a href="#">Cancellations</a></li>
          <li><a href="#">Support Node</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-clean-dock d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
      <div class="d-flex flex-column flex-md-row align-items-center gap-3">
        <span class="copyright-pill">© 2026 Atithi, Inc.</span>
        <div class="dock-links-array">
          <a href="#">Privacy Policy</a>
          <a href="#">Terms of Service</a>
          <a href="#">Sitemap</a>
        </div>
      </div>
      
      <div class="dock-social-deck">
        <a href="#" class="social-minimal-item" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
        <a href="#" class="social-minimal-item" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
        <a href="#" class="social-minimal-item" aria-label="GitHub"><i class="bi bi-github"></i></a>
      </div>
    </div>
  </div>
</footer>

<script>
document.addEventListener("DOMContentLoaded", function() {
    const form = document.getElementById("newsletterForm");
    if(form) {
        form.addEventListener("submit", async function(e) {
            e.preventDefault();
            const emailInput = document.getElementById("newsletterEmail");
            const btn = document.getElementById("newsletterBtn");
            const targetEmail = emailInput.value.trim();
            
            if(!targetEmail) return;

            btn.disabled = true;
            btn.textContent = "...";

            try {
                const response = await fetch("/api/newsletter/subscribe", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ subscriberEmail: targetEmail })
                });

                const result = await response.json();
                if (result.success) {
                    alert("🎉 Subscription Confirmed! Beautiful scenery email successfully dispatched to your inbox.");
                    emailInput.value = "";
                } else {
                    alert("Server Error: " + result.message);
                }
            } catch(err) {
                console.error("Pipeline failed:", err);
                alert("Network pipeline exception occurred.");
            } finally {
                btn.disabled = false;
                btn.textContent = "Join";
            }
        });
    }
});
</script>
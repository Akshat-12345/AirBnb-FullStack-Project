<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
  :root {
    /* Atithi Signature Creative Colors Blueprint */
    --atithi-orange: #FF9432;
    --atithi-green: #67B636;
    --atithi-blue: #00A3E0;
    
    --bg-clean-canvas: #fcfcfd;
    --text-slate-dark: #0f172a;
    --text-slate-muted: #64748b;
    --border-divider: rgba(0, 0, 0, 0.06);
    --font-premium-stack: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto, sans-serif;
  }

  body { font-family: var(--font-premium-stack); }

  .footer-clean-engine {
    background-color: var(--bg-clean-canvas);
    border-top: 1px solid var(--border-divider);
    padding-top: 70px;
    padding-bottom: 40px;
    position: relative;
  }

  .footer-brand-block {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-right: 30px; 
  }
  
  .footer-logo-img {
    height: 36px;
    object-fit: contain;
  }

  /* 🌟 FIXED SPECIFICATION: Squeezed text fixed to breathe luxuriously */
  .footer-logo-text {
    font-weight: 800;
    font-size: 28px;
    letter-spacing: -0.3px; /* 🌟 FIXED: Removed extreme contraction (-1px) so alphabets sync with the logo */
    background: linear-gradient(135deg, var(--atithi-orange) 0%, var(--atithi-green) 50%, var(--atithi-blue) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: inline-block;
  }
  
  .footer-brand-desc {
    font-size: 14.5px;
    color: var(--text-slate-muted);
    line-height: 1.6;
    font-weight: 500;
    margin-bottom: 8px;
  }

  /* Stripe-Style Micro Newsletter Hub */
  .footer-newsletter-form {
    display: flex;
    gap: 10px;
    max-width: 320px;
    margin-top: 4px;
    position: relative;
  }
  .newsletter-input {
    flex: 1;
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 12px;
    padding: 11px 14px;
    font-size: 13.5px;
    font-weight: 500;
    outline: none;
    transition: all 0.25s ease;
  }
  .newsletter-input:focus {
    border-color: var(--atithi-orange);
    box-shadow: 0 0 0 4px rgba(255, 148, 50, 0.12);
  }
  .newsletter-submit-btn {
    background: var(--text-slate-dark);
    color: white;
    border: none;
    border-radius: 12px;
    padding: 11px 18px;
    font-size: 13.5px;
    font-weight: 600;
    transition: all 0.2s ease;
    cursor: pointer;
  }
  .newsletter-submit-btn:hover {
    background: #000000;
    transform: translateY(-1px);
  }

  .footer-col-deck h6 {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    margin-bottom: 24px;
    display: inline-block;
  }

  /* Exact brand color sync mapping */
  .row .footer-col-deck:nth-of-type(2) h6 { color: var(--atithi-orange); }
  .row .footer-col-deck:nth-of-type(3) h6 { color: var(--atithi-green); }
  .row .footer-col-deck:nth-of-type(4) h6 { color: var(--atithi-blue); }
  .row .footer-col-deck:nth-of-type(5) h6 { color: var(--atithi-orange); }

  .footer-col-deck ul {
    list-style: none;
    padding-left: 0;
    margin-bottom: 0;
  }

  .footer-col-deck ul li {
    margin-bottom: 14px;
  }

  .footer-col-deck ul li a {
    font-size: 14.5px;
    font-weight: 500;
    color: var(--text-slate-muted);
    text-decoration: none;
    display: inline-block;
    transition: all 0.22s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* 🚀 ADVANCED UX: Added subtle elegant horizontal slide transition on hover */
  .footer-col-deck ul li a:hover {
    transform: translateX(4px); 
  }
  
  /* Precision hover color transformations matching brand tags */
  .row .footer-col-deck:nth-of-type(2) ul li a:hover { color: var(--atithi-orange); }
  .row .footer-col-deck:nth-of-type(3) ul li a:hover { color: var(--atithi-green); }
  .row .footer-col-deck:nth-of-type(4) ul li a:hover { color: var(--atithi-blue); }
  .row .footer-col-deck:nth-of-type(5) ul li a:hover { color: var(--atithi-orange); }

  /* === 4. MINIMALIST BOTTOM CREDITS DOCK === */
  .footer-clean-dock {
    border-top: 1px solid var(--border-divider);
    margin-top: 50px;
    padding-top: 30px;
    font-size: 14px;
  }

  .copyright-pill {
    font-weight: 600;
    color: var(--text-slate-dark);
  }

  .dock-links-array {
    display: flex;
    gap: 24px;
  }

  .dock-links-array a {
    color: var(--text-slate-muted);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .dock-links-array a:hover {
    color: #000000;
  }

  .dock-social-deck {
    display: flex;
    gap: 20px;
  }

  .social-minimal-item {
    font-size: 16px;
    color: var(--text-slate-muted);
    text-decoration: none;
    transition: all 0.2s ease;
    display: inline-block;
  }

  .social-minimal-item:hover {
    transform: scale(1.15) translateY(-1px);
    color: #000000;
  }
</style>

<footer class="footer footer-clean-engine">
  <div class="container">
    <div class="row">
      <div class="col-12 col-lg-4 mb-5 mb-lg-0 footer-brand-block">
        <div class="d-flex align-items-center gap-3">
          <img src="/images/airbnb.png" alt="Atithi Logo" class="footer-logo-img">
          <span class="footer-logo-text">Atithi</span>
        </div>
        <p class="footer-brand-desc">
          Discover localized stay paradigms and premium group experiences. Stay integrated, travel unified.
        </p>
        
        <form class="footer-newsletter-form" id="newsletterForm">
          <input type="email" class="newsletter-input" id="newsletterEmail" placeholder="Subscribe to our updates" required>
          <button class="newsletter-submit-btn" type="submit" id="newsletterBtn">Join</button>
        </form>
      </div>

      <div class="col-6 col-md-3 col-lg-2 mb-4 footer-col-deck">
        <h6>About</h6>
        <ul>
          <li><a href="#">How Atithi Works</a></li>
          <li><a href="#">Newsroom Logs</a></li>
          <li><a href="#">Investors Capital</a></li>
          <li><a href="#">Atithi Plus</a></li>
        </ul>
      </div>

      <div class="col-6 col-md-3 col-lg-2 mb-4 footer-col-deck">
        <h6>Community</h6>
        <ul>
          <li><a href="#">Diversity</a></li>
          <li><a href="#">Accessibility</a></li>
          <li><a href="#">Invite Associates</a></li>
        </ul>
      </div>

      <div class="col-6 col-md-3 col-lg-2 mb-4 footer-col-deck">
        <h6>Hosting</h6>
        <ul>
          <li><a href="/listings/new">Try Hosting</a></li>
          <li><a href="#">AirCover</a></li>
          <li><a href="#">Resources</a></li>
        </ul>
      </div>

      <div class="col-6 col-md-3 col-lg-2 mb-4 footer-col-deck">
        <h6>Support</h6>
        <ul>
          <li><a href="#">Help Centre</a></li>
          <li><a href="#">Cancellations</a></li>
          <li><a href="#">Support Node</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-clean-dock d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
      <div class="d-flex flex-column flex-md-row align-items-center gap-3">
        <span class="copyright-pill">© 2026 Atithi, Inc.</span>
        <div class="dock-links-array">
          <a href="#">Privacy Policy</a>
          <a href="#">Terms of Service</a>
          <a href="#">Sitemap</a>
        </div>
      </div>
      
      <div class="dock-social-deck">
        <a href="#" class="social-minimal-item" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
        <a href="#" class="social-minimal-item" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
        <a href="#" class="social-minimal-item" aria-label="GitHub"><i class="bi bi-github"></i></a>
      </div>
    </div>
  </div>
</footer>

<script>
document.addEventListener("DOMContentLoaded", function() {
    const form = document.getElementById("newsletterForm");
    if(form) {
        form.addEventListener("submit", async function(e) {
            e.preventDefault();
            const emailInput = document.getElementById("newsletterEmail");
            const btn = document.getElementById("newsletterBtn");
            const targetEmail = emailInput.value.trim();
            
            if(!targetEmail) return;

            btn.disabled = true;
            btn.textContent = "...";

            try {
                const response = await fetch("/api/newsletter/subscribe", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ subscriberEmail: targetEmail })
                });

                const result = await response.json();
                if (result.success) {
                    alert("🎉 Subscription Confirmed! Beautiful scenery email successfully dispatched to your inbox.");
                    emailInput.value = "";
                } else {
                    alert("Server Error: " + result.message);
                }
            } catch(err) {
                console.error("Pipeline failed:", err);
                alert("Network pipeline exception occurred.");
            } finally {
                btn.disabled = false;
                btn.textContent = "Join";
            }
        });
    }
});
</script>
<style>
  /* === 🌌 ULTRA-MODERN IMMERSIVE CORE BLUEPRINTS === */
  .atithi-hero-stage {
    width: 100%;
    position: relative;
    height: 72vh; /* Expanded vertical viewport footprint for grand theater reveal */
    border-radius: 24px;
    overflow: hidden;
    background-color: #0b0f19;
    box-shadow: 0 25px 60px rgba(15, 23, 42, 0.12);
    margin-bottom: 45px;
  }

  /* Structural Core Asset Canvas Background Element */
  .hero-parallax-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }
  
  .hero-parallax-backdrop img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.002);
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .atithi-hero-stage:hover .hero-parallax-backdrop img {
    transform: scale(1.025); /* Silky slow-motion internal push scale */
  }

  /* === 🎭 DOUBLE-GRADIENT LUXURY PROTECTION VEIL === */
  .hero-cinematic-shroud {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    /* Layered mask splits contrast perfectly from bottom typography to top HUD buttons */
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.45) 0%, transparent 40%, rgba(15, 23, 42, 0.88) 100%);
    z-index: 2;
    pointer-events: none;
  }

  /* === 🎛️ INTEGRATED HUD ARCHITECTURE PANELS === */
  .hero-hud-interface {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 3;
    padding: 40px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-sizing: border-box;
  }

  /* Top Section Controller Strip */
  .hud-top-deck {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .hud-luxe-capsule {
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.25);
    padding: 10px 18px;
    border-radius: 40px;
    font-size: 12.5px;
    font-weight: 700;
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    letter-spacing: 0.2px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    text-shadow: 0 1px 2px rgba(0,0,0,0.2);
  }

  .hud-action-circle-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.95);
    border: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #0f172a;
    font-size: 16px;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    transition: all 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .hud-action-circle-btn:hover {
    transform: scale(1.1) translateY(-2px);
    background: #ffffff;
    color: #ff385c;
    box-shadow: 0 12px 30px rgba(255, 56, 92, 0.25);
  }

  /* === 🏷️ INTEGRATED BOTTOM TYPOGRAPHY OVERLAY SYSTEM === */
  .hud-bottom-content-stack {
    width: 100%;
    max-width: 900px;
    text-align: left;
  }

  .hud-master-headline {
    color: #ffffff !important;
    font-size: 42px; /* Grand luxury text scale mapping */
    font-weight: 800;
    letter-spacing: -1.2px;
    line-height: 1.15;
    margin-bottom: 16px;
    text-shadow: 0 4px 25px rgba(15, 23, 42, 0.6);
  }

  .hud-meta-blend-row {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 15px;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.95);
    flex-wrap: wrap;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
  }

  .hud-rating-pill {
    background: #ffffff;
    color: #0f172a;
    padding: 4px 10px;
    border-radius: 8px;
    font-weight: 800;
    font-size: 13.5px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }

  .hud-meta-link {
    color: #ffffff !important;
    text-decoration: underline;
    font-weight: 700;
    transition: color 0.2s ease;
  }
  .hud-meta-link:hover {
    color: var(--atithi-orange) !important;
  }

  .hud-location-anchor {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: rgba(255, 255, 255, 0.9) !important;
    font-weight: 600;
  }

  /* === ⚡ NEW: FROSTED COZY FLASH TOAST NOTIFICATION === */
  .atithi-flash-toast {
    position: fixed;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: rgba(15, 23, 42, 0.9);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #ffffff;
    padding: 14px 28px;
    border-radius: 50px;
    font-size: 14.5px;
    font-weight: 700;
    letter-spacing: -0.1px;
    display: flex;
    align-items: center;
    gap: 10px;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3);
    z-index: 9999;
    opacity: 0;
    pointer-events: none;
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.3s ease;
  }

  .atithi-flash-toast.show-flash {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>

<!-- 🌟 MASTER CINEMATIC STAGE MATRIX -->
<div class="atithi-hero-stage">
  
  <!-- Parallax Asset Background Container Node -->
  <div class="hero-parallax-backdrop">
    <img src="<%= data.image.url %>" alt="<%= data.title %>">
  </div>

  <!-- Dual Shroud Anti-Glow Shadow Canvas Filters -->
  <div class="hero-cinematic-shroud"></div>

  <!-- Immersive Interactive Core HUD Panels Workspace -->
  <div class="hero-hud-interface">
    
    <!-- TOP STRIP CONTEXT DECK -->
    <div class="hud-top-deck">
      <div class="d-flex gap-2">
        <div class="hud-luxe-capsule">
          <span class="d-inline-block rounded-circle bg-success" style="width: 7px; height: 7px; box-shadow: 0 0 10px #67B636;"></span>
          <i class="bi bi-shield-check text-success"></i> Premium Verified Stay
        </div>
      </div>

      <!-- Action Automation Buttons Deck -->
      <div class="d-flex gap-3" style="pointer-events: auto;">
        <button class="hud-action-circle-btn" title="Share Configurations Matrix" onclick="copyShareLink()">
          <i class="bi bi-share-fill" style="font-size: 14px;"></i>
        </button>
        <button class="hud-action-circle-btn" title="Save Asset Node Location" onclick="this.querySelector('i').classList.toggle('bi-heart'); this.querySelector('i').classList.toggle('bi-heart-fill'); this.querySelector('i').style.color='#ff385c'">
          <i class="bi bi-heart" style="font-size: 14px;"></i>
        </button>
      </div>
    </div>

    <!-- BOTTOM SEGMENT INTEGRATED METADATA STACK -->
    <div class="hud-bottom-content-stack">
      <h1 class="hud-master-headline"><%= data.title %></h1>
      
      <div class="hud-meta-blend-row">
        <% if (reviewCount > 0) { %>
          <div class="hud-rating-pill">
            <i class="bi bi-star-fill text-warning"></i>
            <span><%= avgRating %></span>
          </div>
          <span style="opacity: 0.6;">&middot;</span>
          <a href="#reviews" class="hud-meta-link"><%= reviewCount %> Verified Reviews</a>
        <% } else { %>
          <div class="hud-rating-pill" style="background: rgba(255,255,255,0.2); color: #fff; border: 1px solid rgba(255,255,255,0.25);">
            <i class="bi bi-star"></i> <span>New Horizon</span>
          </div>
        <% } %>
        
        <span style="opacity: 0.6;">&middot;</span>
        
        <div class="hud-location-anchor">
          <i class="bi bi-geo-alt-fill text-danger"></i>
          <span><%= data.location %>, <%= data.country %></span>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- 🌟 DYNAMIC TOAST FLASH POPUP MOUNT NODE -->
<div id="flashToast" class="atithi-flash-toast">
  <i class="bi bi-link-45deg text-success fs-5"></i>
  <span>Link copied to clipboard workspace!</span>
</div>

<!-- HUD FUNCTIONALITY CORE JAVASCRIPT PIPELINES -->
<script>
  function copyShareLink() {
    // Copies link smoothly into device stack
    navigator.clipboard.writeText(window.location.href);
    
    // Deploys the dynamic flash toast node seamlessly
    const toast = document.getElementById("flashToast");
    toast.classList.add("show-flash");
    
    // Auto-wipes the notification tracking array after 2500ms
    setTimeout(() => {
      toast.classList.remove("show-flash");
    }, 2500);
  }
</script>
<style>
  :root {
    --atithi-orange: #FF9432;
    --atithi-green: #67B636;
    --atithi-blue: #00A3E0;
    --text-slate-dark: #0f172a;
    --text-slate-muted: #475569;
  }

  /* === 🏷️ CLEAN TOP HEADER DECK === */
  .header-top-title-deck {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    width: 100%;
    margin-bottom: 16px;
  }

  .header-master-title {
    color: var(--text-slate-dark) !important;
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.6px;
    line-height: 1.2;
    margin: 0;
  }

  .header-meta-inline-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 600;
    color: var(--text-slate-muted);
    margin-top: 6px;
  }

  .header-rating-inline {
    color: var(--text-slate-dark);
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .header-meta-link {
    color: var(--text-slate-muted) !important;
    text-decoration: underline;
    transition: color 0.2s ease;
  }
  .header-meta-link:hover {
    color: #000000 !important;
  }

  /* Action Buttons Group */
  .header-utility-actions {
    display: flex;
    gap: 16px;
  }

  .header-text-action-btn {
    background: transparent;
    border: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text-slate-dark);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    padding: 6px 10px;
    border-radius: 8px;
    transition: background-color 0.2s ease;
    text-decoration: underline;
  }
  
  .header-text-action-btn:hover {
    background-color: #f1f5f9;
  }

  /* === 📸 PHOTO REGION PIPELINE MATRIX === */
  .atithi-photo-grid-wrapper {
    position: relative;
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 20px;
  }

  .gallery-img-element {
    width: 100%;
    object-fit: cover;
    transition: filter 0.2s ease;
    cursor: pointer;
  }

  .gallery-img-element:hover {
    filter: brightness(0.9);
  }

  .hero-badi-frame {
    height: 420px;
  }

  .sub-choti-frame {
    height: 206px;
  }

  /* Grid Fallback Style if images are missing */
  .grid-empty-placeholder {
    width: 100%;
    height: 206px;
    background-color: #f8fafc;
    border: 1px dashed #cbd5e1;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #94a3b8;
  }

  /* Show All Photos Button Custom Absolute Overlay */
  .btn-show-all-photos-overlay {
    position: absolute;
    bottom: 24px;
    right: 24px;
    background: #ffffff;
    border: 1px solid #222222;
    padding: 7px 15px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    color: #222222;
    box-shadow: 0px 2px 4px rgba(0,0,0,0.18);
    z-index: 5;
    transition: transform 0.15s ease, background-color 0.15s ease;
  }

  .btn-show-all-photos-overlay:hover {
    transform: scale(1.02);
    background-color: #f7f7f7;
  }

  /* === 🎭 IMMERSIVE FULL VIEWPORT PHOTO TOUR OVERLAY PORTAL === */
  .photo-tour-overlay-portal {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    background-color: #ffffff;
    z-index: 10000;
    display: flex;
    flex-direction: column;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .photo-tour-overlay-portal.portal-active {
    opacity: 1;
    pointer-events: auto;
  }

  /* Top HUD Navigation Bar */
  .tour-top-hud {
    height: 70px;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    border-bottom: 1px solid #f1f5f9;
    background: #ffffff;
    box-sizing: border-box;
  }

  .tour-close-trigger {
    background: transparent;
    border: none;
    font-size: 15px;
    font-weight: 600;
    color: #0f172a;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 8px;
    transition: background-color 0.2s ease;
  }

  .tour-close-trigger:hover {
    background-color: #f1f5f9;
  }

  .tour-hud-title {
    font-size: 15px;
    color: #475569;
  }

  /* Split Content Area Workspace */
  .tour-layout-container {
    display: flex;
    flex: 1;
    height: calc(100vh - 70px);
    overflow: hidden;
    width: 100%;
  }

  /* Left Sticky Reference Sidebar */
  .tour-sidebar-nav {
    width: 320px;
    padding: 40px;
    border-right: 1px solid #e2e8f0;
    box-sizing: border-box;
    background: #ffffff;
  }

  .nav-tour-anchors {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .nav-tour-anchors li {
    padding: 12px 16px;
    border-radius: 10px;
    font-size: 14.5px;
    font-weight: 600;
    color: #475569;
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-tour-anchors li:hover {
    background-color: #f8fafc;
    color: #0f172a;
  }

  .nav-tour-anchors li.active-anchor {
    background-color: #f1f5f9;
    color: #0f172a;
    border-left: 3px solid #0f172a;
    border-radius: 0 10px 10px 0;
  }

  .tour-badge-count {
    font-size: 11px;
    background: #e2e8f0;
    color: #334155;
    padding: 2px 8px;
    border-radius: 20px;
    font-weight: 700;
  }

  .nav-tour-anchors li.active-anchor .tour-badge-count {
    background: #0f172a;
    color: #ffffff;
  }

  /* Right Side Scrollable Lens Flow Frame */
  .tour-gallery-scroll-feed {
    flex: 1;
    padding: 40px 6% 80px 6%;
    overflow-y: auto;
    background-color: #ffffff;
    scroll-behavior: smooth;
  }

  .tour-category-section {
    margin-bottom: 50px;
  }

  .tour-section-title {
    font-size: 22px;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 20px;
    border-bottom: 1px solid #f1f5f9;
    padding-bottom: 10px;
    text-transform: capitalize;
  }

  .tour-lens-graphic {
    width: 100%;
    height: auto;
    max-height: 85vh;
    object-fit: cover;
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.015);
  }

  /* Prevent body behind the modal from scrolling */
  .body-lock-scroll {
    overflow: hidden !important;
  }

  /* === ⚡ FROSTED FLASH TOAST === */
  .atithi-flash-toast {
    position: fixed;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: rgba(15, 23, 42, 0.9);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #ffffff;
    padding: 14px 28px;
    border-radius: 50px;
    font-size: 14.5px;
    font-weight: 700;
    z-index: 9999;
    opacity: 0;
    pointer-events: none;
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.3s ease;
  }

  .atithi-flash-toast.show-flash {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>

<div class="header-top-title-deck">
  <div>
    <h1 class="header-master-title"><%= data.title %></h1>
    
    <div class="header-meta-inline-row">
      <% if (typeof reviewCount !== 'undefined' && reviewCount > 0) { %>
        <span class="header-rating-inline">
          <i class="bi bi-star-fill text-dark" style="font-size: 13px;"></i> <%= avgRating %>
        </span>
        <span>&middot;</span>
        <a href="#reviews" class="header-meta-link"><%= reviewCount %> Reviews</a>
      <% } else { %>
        <span class="header-rating-inline">
          <i class="bi bi-star"></i> New Horizon
        </span>
      <% } %>
      <span>&middot;</span>
      <span class="d-inline-flex align-items-center gap-1">
        <i class="bi bi-geo-alt-fill text-dark" style="font-size: 13px;"></i>
        <%= data.location %>, <%= data.country %>
      </span>
    </div>
  </div>

  <div class="header-utility-actions">
    <button class="header-text-action-btn" onclick="copyShareLink()">
      <i class="bi bi-share" style="font-size: 15px; -webkit-text-stroke: 0.5px;"></i> <u>Share</u>
    </button>
    <button class="header-text-action-btn" onclick="this.querySelector('i').classList.toggle('bi-heart'); this.querySelector('i').classList.toggle('bi-heart-fill'); this.querySelector('i').style.color=this.querySelector('i').classList.contains('bi-heart-fill')?'#ff385c':'#000000'">
      <i class="bi bi-heart" style="font-size: 15px; -webkit-text-stroke: 0.5px;"></i> <u>Save</u>
    </button>
  </div>
</div>

<div class="atithi-photo-grid-wrapper">
  <% if(data.images && data.images.length > 0) { %>
    
    <% if(data.images.length === 1) { %>
      <div class="row g-2">
        <div class="col-12">
          <img src="<%= data.images[0].url %>" class="gallery-img-element hero-badi-frame" alt="<%= data.title %>">
        </div>
      </div>
    <% } else { %>
      <div class="row g-2">
        
        <div class="col-md-6">
          <img src="<%= data.images[0].url %>" class="gallery-img-element hero-badi-frame" alt="Main View Grid">
        </div>

        <div class="col-md-6">
          <div class="row g-2">
            <% for(let i = 1; i < Math.min(data.images.length, 5); i++) { %>
              <div class="col-6">
                <img src="<%= data.images[i].url %>" class="gallery-img-element sub-choti-frame" alt="Sub Grid Node">
              </div>
            <% } %>

            <% if(data.images.length < 5) { %>
              <% for(let j = data.images.length; j < 5; j++) { %>
                <div class="col-6">
                  <div class="grid-empty-placeholder">
                    <i class="bi bi-images" style="font-size: 1.4rem;"></i>
                  </div>
                </div>
              <% j++ } %>
            <% } %>
          </div>
        </div>

      </div>
    <% } %>

    <button class="btn btn-show-all-photos-overlay d-flex align-items-center gap-2">
      <i class="bi bi-grid-3x3-gap-fill" style="font-size: 14px;"></i> Show all photos
    </button>

  <% } else { %>
    <div class="row g-2">
      <div class="col-12">
        <img src="https://images.unsplash.com/photo-1584132967334-10e028bd69f7" class="gallery-img-element hero-badi-frame" alt="Default Blueprint Fallback">
      </div>
    </div>
  <% } %>
</div>

<!-- === 🎭 CATEGORIZED IMMERSIVE PHOTO TOUR PORTAL === -->
<div id="atithiPhotoTourModal" class="photo-tour-overlay-portal">
  
  <div class="tour-top-hud">
    <button class="tour-close-trigger" onclick="closePhotoTour()">
      <i class="bi bi-chevron-left"></i> Close
    </button>
    <div class="tour-hud-title fw-semibold"><%= data.title %> &middot; Photo Tour</div>
  </div>

  <div class="tour-layout-container">
    
    <!-- Left Navigation Menu (Dynamically parsed from modern tags array) -->
    <div class="tour-sidebar-nav d-none d-lg-block">
      <h3 class="fw-bold mb-3" style="font-size: 1.6rem; color: #0f172a; letter-spacing: -0.5px;">Photo tour</h3>
      <ul class="nav-tour-anchors">
        <li class="active-anchor" data-target="all-photos">
          <span><i class="bi bi-images me-2"></i> All Photos</span>
          <span class="tour-badge-count"><%= data.images.length %></span>
        </li>
        
        <!-- Mongoose dynamic check processing tags loop -->
        <% 
          const validTags = ['General', 'Bedroom', 'Kitchen', 'Bathroom', 'Exterior']; 
          validTags.forEach(tag => {
            const count = data.images.filter(img => img.tag === tag).length;
            if(count > 0) {
        %>
          <li data-target="sec-<%= tag.toLowerCase() %>">
            <span>
              <i class="bi <% if(tag==='Bedroom'){ %>%>bi-door-open<% }else if(tag==='Kitchen'){ %>%>bi-egg-fried<% }else if(tag==='Bathroom'){ %>%>bi-droplet<% }else if(tag==='Exterior'){ %>%>bi-tree<% }else{ %>%>bi-building<% } %> me-2"></i>
              <%= tag %>
            </span>
            <span class="tour-badge-count"><%= count %></span>
          </li>
        <% 
            }
          }); 
        %>
      </ul>
    </div>

    <!-- Right Dynamic Scrollable Lens Feed Area Framework -->
    <div class="tour-gallery-scroll-feed" id="tourScrollFeed">
      
      <!-- ALL PHOTOS WRAPPER NODE -->
      <div id="all-photos" class="tour-category-section">
        <h4 class="tour-section-title">All Asset Showcase Matrix</h4>
        <div class="row g-3">
          <% data.images.forEach((img, index) => { %>
            <div class="<%= index % 3 === 0 ? 'col-12' : 'col-md-6' %> mb-3">
              <img src="<%= img.url %>" class="tour-lens-graphic" alt="Asset Flow Element">
            </div>
          <% }) %>
        </div>
      </div>

      <!-- CATEGORY SEPARATED GRIDS PIPELINE -->
      <% validTags.forEach(tag => { 
        const categoryImages = data.images.filter(img => img.tag === tag);
        if(categoryImages.length > 0) {
      %>
        <div id="sec-<%= tag.toLowerCase() %>" class="tour-category-section">
          <h4 class="tour-section-title"><%= tag %> Spaces</h4>
          <div class="row g-3">
            <% categoryImages.forEach((img, index) => { %>
              <div class="<%= index % 3 === 0 ? 'col-12' : 'col-md-6' %> mb-3">
                <img src="<%= img.url %>" class="tour-lens-graphic" alt="<%= tag %> Segment">
              </div>
            <% }) %>
          </div>
        </div>
      <% 
        }
      }); 
      %>
    </div>

  </div>
</div>

<div id="flashToast" class="atithi-flash-toast">
  <i class="bi bi-link-45deg text-success fs-5"></i>
  <span>Link copied to clipboard workspace!</span>
</div>

<script>
  function copyShareLink() {
    navigator.clipboard.writeText(window.location.href);
    const toast = document.getElementById("flashToast");
    toast.classList.add("show-flash");
    setTimeout(() => {
      toast.classList.remove("show-flash");
    }, 2500);
  }

  document.addEventListener('DOMContentLoaded', function() {
    const showAllBtn = document.querySelector('.btn-show-all-photos-overlay');
    if (showAllBtn) {
      showAllBtn.addEventListener('click', openPhotoTour);
    }

    const gridImages = document.querySelectorAll('.atithi-photo-grid-wrapper .gallery-img-element');
    gridImages.forEach(img => {
      img.addEventListener('click', openPhotoTour);
    });

    // Sidebar navigation highlight sync system
    const anchors = document.querySelectorAll('.nav-tour-anchors li');
    const scrollFeed = document.getElementById('tourScrollFeed');
    const sections = document.querySelectorAll('.tour-category-section');

    anchors.forEach(anchor => {
      anchor.addEventListener('click', function() {
        const targetId = this.getAttribute('data-target');
        const targetSection = document.getElementById(targetId);
        
        if(targetSection) {
          targetSection.scrollIntoView({ behavior: 'smooth' });
          anchors.forEach(a => a.classList.remove('active-anchor'));
          this.classList.add('active-anchor');
        }
      });
    });

    // Scroll listener inside modal for dynamic link highlighting
    scrollFeed.addEventListener('scroll', function() {
      let currentSectionId = "all-photos";
      
      sections.forEach(sec => {
        const top = sec.offsetTop - scrollFeed.offsetTop;
        if (scrollFeed.scrollTop >= top - 60) {
          currentSectionId = sec.getAttribute('id');
        }
      });

      anchors.forEach(anchor => {
        if(anchor.getAttribute('data-target') === currentSectionId) {
          anchor.classList.add('active-anchor');
        } else {
          anchor.classList.remove('active-anchor');
        }
      });
    });
  });

  function openPhotoTour() {
    const portal = document.getElementById("atithiPhotoTourModal");
    if (portal) {
      portal.classList.add("portal-active");
      document.body.classList.add("body-lock-scroll");
    }
  }

  function closePhotoTour() {
    const portal = document.getElementById("atithiPhotoTourModal");
    if (portal) {
      portal.classList.remove("portal-active");
      document.body.classList.remove("body-lock-scroll");
    }
  }
</script>
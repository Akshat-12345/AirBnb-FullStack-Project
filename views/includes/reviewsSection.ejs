<style>
  /* === Review Section Container Styles === */
  .reviews-section { 
    margin-top: 48px; 
    padding-top: 32px;
    border-top: 1px solid var(--border-color);
  }
  .reviews-header { 
    font-size: 24px; 
    font-weight: 600; 
    margin-bottom: 28px; 
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .reviews-header i {
    color: var(--primary-color);
  }

  /* === Modern Grid Layout for Cards === */
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(48%, 1fr));
    gap: 24px 4%;
    margin-bottom: 32px;
  }

  .review-card { 
    background-color: #ffffff; 
    padding: 12px 0;
    display: flex;
    flex-direction: column;
  }
  
  .review-header-block { 
    display: flex; 
    align-items: center; 
    gap: 14px; 
    margin-bottom: 12px; 
  }
  
  .review-author-avatar { 
    width: 48px; 
    height: 48px; 
    background: linear-gradient(135deg, #ff385c, #e61e4d); 
    color: white; 
    font-size: 18px; 
    font-weight: 600; 
    border-radius: 50%; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    text-transform: uppercase; 
    box-shrink: 0;
    box-shadow: 0 2px 6px rgba(0,0,0,0.08);
  }
  
  .review-author-details h5 { 
    font-size: 16px; 
    font-weight: 600; 
    margin: 0 0 2px 0; 
  }
  
  .review-date { 
    color: var(--text-light); 
    font-size: 14px; 
  }
  
  .review-rating-stars { 
    display: flex; 
    align-items: center; 
    gap: 2px; 
    margin-bottom: 8px; 
  }
  
  .review-rating-stars span { 
    font-size: 14px; 
    color: var(--star-color); 
  }
  
  .review-rating-value { 
    font-weight: 600; 
    font-size: 13px;
    margin-left: 6px; 
    color: var(--text-dark); 
  }
  
  .review-comment { 
    color: var(--text-dark); 
    line-height: 1.5; 
    font-size: 15px;
    margin-bottom: 4px;
    max-height: 72px; 
    overflow: hidden; 
    position: relative; 
    white-space: pre-line;
    transition: max-height 0.3s ease-out; 
  }
  
  .review-comment.expanded { 
    max-height: 1000px; 
  }
  
  .show-more-btn { 
    font-weight: 600; 
    cursor: pointer; 
    text-decoration: underline; 
    color: var(--text-dark);
    font-size: 14px;
    display: inline-block;
    margin-bottom: 8px;
  }
  .show-more-btn:hover { 
    color: var(--primary-color); 
  }

  /* === Clean Leave Review Form Layout === */
  .review-form-section {
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid var(--border-color);
  }
  .review-form-container { 
    background-color: var(--background-light); 
    border-radius: 16px; 
    padding: 32px; 
  }
  .review-form-container h3 {
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 4px;
  }
  .star-rating-form { 
    display: flex; 
    flex-direction: row-reverse; 
    justify-content: flex-end; 
    gap: 6px; 
  }
  .star-rating-form input[type="radio"] { display: none; }
  .star-rating-form label { 
    font-size: 2rem; 
    color: #cbd5e1; 
    cursor: pointer; 
    transition: color 0.2s ease-in-out, transform 0.1s ease; 
  }
  .star-rating-form label:hover, 
  .star-rating-form label:hover ~ label, 
  .star-rating-form input[type="radio"]:checked ~ label { 
    color: var(--star-color); 
  }
  .form-control-review { 
    width: 100%;
    border-radius: 8px; 
    border: 1px solid var(--border-color); 
    padding: 12px; 
    min-height: 100px; 
    font-size: 15px;
  }
  .form-control-review:focus { 
    outline: none;
    border-color: var(--text-dark); 
  }
  .btn-submit-review { 
    background: var(--text-dark); 
    color: white; 
    font-weight: 600; 
    font-size: 15px; 
    border: none; 
    border-radius: 8px; 
    padding: 12px 24px; 
    transition: background-color 0.2s ease; 
  }
  .btn-submit-review:hover { 
    background: #000000; 
  }

  /* Responsive Adjustments */
  @media (max-width: 768px) {
    .reviews-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .review-card {
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 16px;
    }
  }
</style>

<div class="reviews-section" id="reviews">
  <h3 class="reviews-header">
    <% if (reviewCount > 0) { %>
      <i class="bi bi-star-fill"></i> <%= avgRating %> &middot; <%= reviewCount %> <%= reviewCount === 1 ? 'review' : 'reviews' %>
    <% } else { %>
      No reviews yet
    <% } %>
  </h3>

  <div class="reviews-grid">
    <% for(let review of data.reviews) { %>
      <div class="review-card">
        <div class="review-header-block">
          <div class="review-author-avatar">
            <%= review.author.username.charAt(0).toUpperCase() %>
          </div>
          <div class="review-author-details">
            <h5><%= review.author.username %></h5>
            <div class="review-date">
              <%= new Date(review.createdAt || Date.now()).toLocaleDateString("en-US", { month: "long", year: "numeric" }) %>
            </div>
          </div>
        </div>

        <div class="review-rating-stars">
          <% for(let i=1; i<=5; i++){ %>
            <% if(i <= review.rating){ %>
              <span>★</span>
            <% } else { %>
              <span style="color:#e2e8f0;">★</span>
            <% } %>
          <% } %>
          <span class="review-rating-value"><%= review.rating %>.0</span>
        </div>

        <p class="review-comment"><%= review.comment %></p>
        <a class="show-more-btn" style="display:none;">Show more</a>

        <% if (currUser && currUser._id.equals(review.author._id)){ %>
          <form action="/listings/<%= data._id %>/reviews/<%= review._id %>?_method=DELETE" method="post" class="mt-2">
            <button type="submit" class="btn btn-link p-0 text-danger text-decoration-none fw-semibold small">
              <i class="bi bi-trash"></i> Delete Review
            </button>
          </form>
        <% } %>
      </div>
    <% } %>
  </div>
</div>

<% if(currUser){ %>
  <div class="review-form-section">
    <div class="review-form-container">
      <h3>Leave a Review</h3>
      <p class="text-secondary small">Share your structural stay feedback parameters to guide traveler nodes.</p>
      <form action="/listings/<%= data._id %>/reviews" method="POST" novalidate class="needs-validation mt-3">
        <div class="mb-3">
          <label class="form-label fw-semibold small">Your Rating</label>
          <div class="star-rating-form">
            <input type="radio" id="star5" name="review[rating]" value="5" required><label for="star5" title="5 stars">★</label>
            <input type="radio" id="star4" name="review[rating]" value="4"><label for="star4" title="4 stars">★</label>
            <input type="radio" id="star3" name="review[rating]" value="3"><label for="star3" title="3 stars">★</label>
            <input type="radio" id="star2" name="review[rating]" value="2"><label for="star2" title="2 stars">★</label>
            <input type="radio" id="star1" name="review[rating]" value="1"><label for="star1" title="1 star">★</label>
          </div>
        </div>
        <div class="mb-3">
          <label for="comment" class="form-label fw-semibold small">Your Comment</label>
          <textarea name="review[comment]" id="comment" rows="3" class="form-control-review" placeholder="How was your experience at this property stay?" required></textarea>
        </div>
        <button class="btn-submit-review">Submit Review</button>
      </form>
    </div>
  </div>
<% } %>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const comments = document.querySelectorAll('.review-comment');
    comments.forEach(comment => {
        if (comment.scrollHeight > 72) {
            const btn = comment.nextElementSibling;
            if (btn && btn.classList.contains('show-more-btn')) {
                btn.style.display = 'inline-block';
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    comment.classList.toggle('expanded');
                    this.textContent = comment.classList.contains('expanded') ? 'Show less' : 'Show more';
                });
            }
        }
    });
});
</script>
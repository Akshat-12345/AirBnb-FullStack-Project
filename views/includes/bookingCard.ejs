<style>
  /* === 👑 ATITHI EXECUTIVE LUXURY CONTAINER CHASSIS === */
  .atithi-premium-card-vault {
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 24px;
    padding: 36px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.04);
    position: sticky;
    top: 110px;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .atithi-premium-card-vault:hover {
    transform: translateY(-4px);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.08);
  }

  /* Sophisticated Clean Pricing Typography */
  .premium-price-blueprint {
    font-size: 26px;
    font-weight: 800;
    letter-spacing: -0.7px;
    color: #111111;
    margin-bottom: 0;
    display: flex;
    align-items: baseline;
    gap: 4px;
  }
  .premium-price-blueprint span {
    font-size: 15px;
    font-weight: 500;
    color: #666666;
    letter-spacing: 0;
  }

  /* Structural Clean Input Grids System */
  .premium-input-grid {
    display: flex;
    flex-direction: column;
    gap: 18px;
    margin-top: 24px;
    margin-bottom: 24px;
  }

  .premium-label-tag {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    color: #222222;
    letter-spacing: 0.8px;
    margin-bottom: 6px;
  }

  /* Ultra-Crisp Custom Input Framework Elements */
  .premium-luxe-input {
    width: 100%;
    border: 1.5px solid #e5e7eb !important;
    border-radius: 12px !important;
    font-size: 14.5px !important;
    font-weight: 600 !important;
    color: #111111 !important;
    background-color: #ffffff !important;
    padding: 13px 16px !important;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1) !important;
  }
  .premium-luxe-input:focus {
    border-color: #111111 !important;
    background-color: #ffffff !important;
    box-shadow: 0 0 0 4px rgba(17, 17, 17, 0.05) !important;
    outline: none !important;
  }

  /* Authentic Clean Premium Switch Engine */
  .premium-apple-switch {
    cursor: pointer;
    width: 2.8em !important;
    height: 1.5em !important;
    border-color: #e5e7eb !important;
    background-color: #e5e7eb !important;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }
  .premium-apple-switch:checked {
    background-color: #222222 !important;
    border-color: #222222 !important;
  }
  .premium-apple-switch:focus {
    box-shadow: none !important;
  }

  /* Co-Travelers Enclave Floating Box */
  .premium-matrix-enclave {
    background-color: #f8fafc !important;
    border: 1px solid #e2e8f0 !important;
    border-radius: 14px !important;
    padding: 20px !important;
    margin-top: 16px;
    box-shadow: inset 0 2px 4px rgba(0,0,0,0.01);
  }

  /* === 💎 SUPREME INTERACTIVE ACTION BUTTON LEVER === */
  .btn-premium-reserve-lever {
    width: 100%;
    padding: 16px;
    background: #111111;
    color: #ffffff;
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.2px;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(17, 17, 17, 0.12);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .btn-premium-reserve-lever:hover {
    background: #000000;
    transform: translateY(-1px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.2);
  }
  .btn-premium-reserve-lever:active {
    transform: translateY(1px);
  }
</style>

<div class="atithi-premium-card-vault">
  
  <div class="d-flex justify-content-between align-items-center">
    <p class="premium-price-blueprint">
      ₹ <%= data.price.toLocaleString("en-IN") %> <span>/ night</span>
    </p>
  </div>
  <hr class="my-3" style="color: #f1f5f9; opacity: 1; border-width: 1.5px;">
  
  <form id="booking-dates-form" novalidate class="needs-validation">
    <div class="premium-input-grid">
      <div>
        <label for="checkInDate" class="premium-label-tag">Check-in Date</label>
        <input type="date" id="checkInDate" class="form-control premium-luxe-input" required>
      </div>
      
      <div>
        <label for="checkOutDate" class="premium-label-tag">Check-out Date</label>
        <input type="date" id="checkOutDate" class="form-control premium-luxe-input" required>
      </div>
    </div>
    
    <div class="form-check form-switch d-flex justify-content-between align-items-center ps-0 mb-3">
      <label class="form-check-label small text-dark fw-bold" for="isSplitBooking" style="cursor: pointer; font-size: 14px;">
        <i class="bi bi-people-fill text-dark me-2" style="font-size: 15px;"></i>Split Bill with Friends?
      </label>
      <input class="form-check-input premium-apple-switch" type="checkbox" id="isSplitBooking" style="margin-left: 0;">
    </div>

    <div id="splitEmailsContainer" class="mb-3 premium-matrix-enclave" style="display: none;">
      <p class="text-secondary mb-3 fw-bold" style="font-size: 10px; letter-spacing: 0.8px; font-family: monospace;">CO-TRAVELERS VERIFICATION MATRIX</p>
      
      <div id="emailInputsList">
        <div class="input-group input-group-sm mb-2" style="border-radius: 10px; overflow: hidden;">
          <span class="input-group-text bg-white border-end-0 text-muted" style="border-color: #e5e7eb; padding-left: 12px;"><i class="bi bi-envelope"></i></span>
          <input type="email" class="form-control border-start-0 shadow-none split-friend-email premium-luxe-input" placeholder="friend1@gmail.com" disabled style="padding: 10px 12px !important; border-radius: 0 10px 10px 0 !important;">
        </div>
      </div>

      <div class="d-flex justify-content-between align-items-center mt-3 pt-2">
        <button type="button" id="addEmailBtn" class="btn btn-sm btn-dark px-3 py-1fw-bold" style="font-size: 11px; border-radius: 8px; font-weight: 600; background: #222222;"><i class="bi bi-plus-lg me-1"></i>Add Friend</button>
        <small class="text-secondary font-monospace" style="font-size: 11px; font-weight: 600;">Max 5 Friends</small>
      </div>
    </div>
  </form>

  <p class="text-muted small mb-3 text-center" style="font-size: 12.5px; font-weight: 500; margin-top: 12px;">This is a rare find. Prices are competitive for these dates.</p>
  <button class="btn-premium-reserve-lever btn-reserve">Reserve Stay</button>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const splitSwitch = document.getElementById("isSplitBooking");
    const emailsContainer = document.getElementById("splitEmailsContainer");
    const emailInputsList = document.getElementById("emailInputsList");
    const addEmailBtn = document.getElementById("addEmailBtn");

    if(splitSwitch) {
      splitSwitch.addEventListener("change", function() {
        if (this.checked) {
          emailsContainer.style.display = "block";
          emailInputsList.querySelectorAll("input").forEach(input => input.disabled = false);
        } else {
          emailsContainer.style.display = "none";
          emailInputsList.querySelectorAll("input").forEach(input => input.disabled = true);
        }
      });
    }

    if(addEmailBtn) {
      addEmailBtn.addEventListener("click", () => {
        const currentInputs = emailInputsList.querySelectorAll("input").length;
        if (currentInputs >= 5) return alert("Maximum 5 friends allowed.");

        const inputGroup = document.createElement("div");
        inputGroup.className = "input-group input-group-sm mb-2";
        inputGroup.style.borderRadius = "10px";
        inputGroup.style.overflow = "hidden";
        inputGroup.innerHTML = `
          <span class="input-group-text bg-white border-end-0 text-muted" style="border-color: #e5e7eb; padding-left: 12px;"><i class="bi bi-envelope"></i></span>
          <input type="email" class="form-control border-start-0 shadow-none split-friend-email premium-luxe-input" placeholder="friend@gmail.com" required style="padding: 10px 12px !important; border-radius: 0 !important;">
          <button type="button" class="btn btn-sm btn-outline-danger border-start-0" onclick="this.parentElement.remove()" style="border-color: #e5e7eb; background: #ffffff; padding: 0 12px;"><i class="bi bi-trash"></i></button>
        `;
        emailInputsList.appendChild(inputGroup);
      });
    }
  });
</script>
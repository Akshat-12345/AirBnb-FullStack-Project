<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
  :root {
    --atithi-orange: #FF9432;
    --atithi-green: #67B636;
    --atithi-blue: #00A3E0;
    --airbnb-red: #FF385C;
    --text-slate-dark: #222222;
    --text-slate-muted: #717171;
  }

  /* === 🌟 1. INTERACTIVE ECOSYSTEM GALLERY GRID === */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); /* Expanded width bounds for dynamic masonry look */
    gap: 16px;
  }

  .gallery-item-wrapper {
    position: relative;
    border-radius: 14px; /* Matches your master grid rounding layout rules */
    overflow: hidden;
    cursor: pointer;
    aspect-ratio: 4 / 3;
    background-color: #f3f4f6;
    border: 1px solid rgba(0, 0, 0, 0.03);
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
  }
  
  .gallery-item-wrapper:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.08);
    border-color: rgba(0, 0, 0, 0.08);
  }

  .gallery-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .gallery-item-wrapper:hover .gallery-media {
    transform: scale(1.04); /* Silky internal zoom animation */
  }

  /* Frosted Video Action Trigger Keycaps */
  .video-overlay-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    color: var(--text-slate-dark);
    border-radius: 50%;
    width: 46px;
    height: 46px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
    font-size: 20px;
    z-index: 5;
    transition: all 0.2s ease;
  }
  .gallery-item-wrapper:hover .video-overlay-icon {
    background: var(--airbnb-red);
    color: #ffffff;
    transform: translate(-50%, -50%) scale(1.08);
    box-shadow: 0 6px 20px rgba(255, 56, 92, 0.3);
  }

  /* === 🌟 2. APPLE-STYLE HIGH-DENSITY LIGHTBOX OVERLAY === */
  .lightbox-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(15, 23, 42, 0.85); /* Dark executive translucent mesh track */
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    z-index: 2000;
    display: none;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .lightbox-overlay.active {
    display: flex;
    opacity: 1;
  }
  
  .lightbox-content-container {
    max-width: 80%;
    max-height: 80vh;
    position: relative;
    transform: scale(0.95);
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .lightbox-overlay.active .lightbox-content-container {
    transform: scale(1);
  }

  .lightbox-media {
    max-width: 100%;
    max-height: 80vh;
    border-radius: 16px;
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .lightbox-close-btn {
    position: absolute;
    top: -50px;
    right: 0;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    font-size: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .lightbox-close-btn:hover {
    background: var(--airbnb-red);
    border-color: var(--airbnb-red);
    color: #ffffff;
    transform: rotate(90deg);
  }
</style>

<% if (approvedMedia && approvedMedia.length > 0) { %>
    <div class="guest-gallery-section mt-5 mb-5">
        <hr class="my-5" style="color: #ebebeb; opacity: 1;">
        
        <!-- Premium Calibrated Heading Segment -->
        <div class="mb-4">
            <h4 class="fw-bold text-dark mb-1" style="letter-spacing: -0.5px; font-size: 20px;">
                <i class="bi bi-patch-check-fill text-primary me-2" style="color: var(--atithi-blue) !important;"></i>Live Guest Experience Gallery
            </h4>
            <p class="text-muted small fw-medium">Visual stay snapshots captured and shared by verified platform voyagers during checkout operations.</p>
        </div>

        <!-- Structural Grid Distribution Pipeline -->
        <div class="gallery-grid">
            <% approvedMedia.forEach(item => { %>
                <% item.photos.forEach((photo, pIdx) => { %>
                    <div class="gallery-item-wrapper" onclick="openLightbox('image', '<%= photo.url %>')">
                        <img src="<%= photo.url %>" class="gallery-media" alt="Verified Stay Log Snapshot">
                    </div>
                <% }) %>

                <% if(item.video && item.video.url) { %>
                    <div class="gallery-item-wrapper" onclick="openLightbox('video', '<%= item.video.url %>')">
                        <video src="<%= item.video.url %>" class="gallery-media" preload="metadata"></video>
                        <div class="video-overlay-icon">
                            <i class="bi bi-play-fill"></i>
                        </div>
                    </div>
                <% } %>
            <% }) %>
        </div>
    </div>
<% } %>

<!-- MASTER LIGHTBOX WORKSTATION STRUCTURE -->
<div id="globalLightbox" class="lightbox-overlay" onclick="closeLightbox()">
    <div class="lightbox-content-container" onclick="event.stopPropagation()">
        <button class="lightbox-close-btn" onclick="closeLightbox()">&times;</button>
        <div id="lightboxMediaVault"></div>
    </div>
</div>

<script>
    function openLightbox(type, url) {
        const lightbox = document.getElementById("globalLightbox");
        const vault = document.getElementById("lightboxMediaVault");
        
        if(type === 'image') {
            vault.innerHTML = `<img src="${url}" class="lightbox-media">`;
        } else if(type === 'video') {
            vault.innerHTML = `<video src="${url}" class="lightbox-media" controls autoplay style="background:#000; width: 100%; max-width: 800px;"></video>`;
        }
        
        lightbox.classList.add("active");
        document.body.style.overflow = "hidden"; 
    }

    function closeLightbox() {
        const lightbox = document.getElementById("globalLightbox");
        const vault = document.getElementById("lightboxMediaVault");
        
        lightbox.classList.remove("active");
        vault.innerHTML = ""; 
        document.body.style.overflow = "auto";
    }

    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeLightbox();
    });
</script>
<style>
  /* === 🏡 MASTER LUXURY CANVAS === */
  .atithi-luxury-editorial-chassis {
    width: 100%;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    color: #222222;
    padding-right: 24px; /* Creates breathing channel between left block and sticky panel */
  }

  /* 🌟 APPLE-STYLE INTERACTIVE HOST ANCHOR */
  .atithi-luxury-host-profile-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 0;
    border-bottom: 1px solid #ededed;
    margin-bottom: 32px;
  }

  .atithi-host-meta-stack {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .atithi-host-meta-stack h3 {
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.5px;
    margin: 0;
    color: #222222;
  }

  .atithi-host-status-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #5ea330; /* Identity Operations Green */
    font-size: 14px;
    font-weight: 500;
  }

  .atithi-host-status-badge i {
    font-size: 15px;
  }

  /* Solid Monochromatic Micro Monogram */
  .atithi-host-avatar-frame {
    width: 52px;
    height: 52px;
    background: #222222;
    color: #ffffff;
    font-weight: 500;
    font-size: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-transform: uppercase;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  /* === 🏷️ PREMIUM ISOLATED FEATURE SPECIFICATION TRACK === */
  .atithi-luxury-spec-matrix {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-bottom: 36px;
  }

  .luxury-spec-node {
    display: flex;
    align-items: flex-start;
    gap: 18px;
  }

  .luxury-spec-icon-box {
    font-size: 24px;
    color: #222222;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 2px;
  }

  .luxury-spec-text-block {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .luxury-spec-text-block h4 {
    font-size: 16px;
    font-weight: 600;
    margin: 0;
    color: #222222;
    letter-spacing: -0.1px;
  }

  .luxury-spec-text-block p {
    font-size: 14px;
    color: #717171;
    margin: 0;
    line-height: 1.45;
  }

  /* === 📑 ARCHITECTURAL READING SLATE (PROSE) === */
  .atithi-editorial-divider-line {
    height: 1px;
    background: #ededed;
    width: 100%;
    margin-bottom: 32px;
  }

  .atithi-luxury-prose-container {
    position: relative;
    margin-bottom: 40px;
  }

  .atithi-luxury-prose-container p {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.75;
    color: #333333; /* Standard high-contrast reading ergonomics layout */
    white-space: pre-line;
    letter-spacing: -0.1px;
  }

  /* === 🛠️ FLAT COMPACT PLATFORM LEVERS === */
  .atithi-luxury-admin-deck {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 36px;
    padding-top: 24px;
    border-top: 1px solid #ededed;
  }

  .btn-luxury-operational-lever {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 13.5px;
    padding: 10px 20px;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none !important;
    transition: all 0.2s cubic-bezier(0.2, 0, 0, 1);
  }

  .btn-luxury-lever-modify {
    background: #222222;
    color: #ffffff;
    border: 1px solid #222222;
  }
  
  .btn-luxury-lever-modify:hover {
    background: #000000;
    border-color: #000000;
    transform: translateY(-1px);
  }

  .btn-luxury-lever-delete {
    background: #ffffff;
    color: #c13515;
    border: 1px solid #c13515;
  }
  
  .btn-luxury-lever-delete:hover {
    background: #fff8f6;
    transform: translateY(-1px);
  }
</style>

<div class="atithi-luxury-editorial-chassis">
  
  <div class="atithi-luxury-host-profile-row">
    <div class="atithi-host-meta-stack">
      <h3>Hosted by <%= data.owner ? data.owner.username : 'Exotic Host' %></h3>
      <div class="atithi-host-status-badge">
        <i class="bi bi-patch-check-fill"></i> Atithi Certified Partner
      </div>
    </div>
    
    <div class="atithi-host-avatar-frame">
      <%= data.owner && data.owner.username ? data.owner.username.charAt(0).toUpperCase() : 'A' %>
    </div>
  </div>

  <div class="atithi-luxury-spec-matrix">
    <div class="luxury-spec-node">
      <div class="luxury-spec-icon-box">
        <i class="bi bi-door-open"></i>
      </div>
      <div class="luxury-spec-text-block">
        <h4>Self check-in via smartlock</h4>
        <p>Check yourself in smoothly with our authenticated keyless system access gateway.</p>
      </div>
    </div>
    
    <div class="luxury-spec-node">
      <div class="luxury-spec-icon-box">
        <i class="bi bi-shield-check"></i>
      </div>
      <div class="luxury-spec-text-block">
        <h4>100% Verified stay matrix</h4>
        <p>Every single detail of this property has been physically audited and vetted by our operations engine.</p>
      </div>
    </div>

    <div class="luxury-spec-node">
      <div class="luxury-spec-icon-box">
        <i class="bi bi-chat-square-heart"></i>
      </div>
      <div class="luxury-spec-text-block">
        <h4>Highly rated host partner</h4>
        <p>This host consistently receives 5-star ratings and exceptional engagement feedbacks.</p>
      </div>
    </div>
  </div>

  <div class="atithi-editorial-divider-line"></div>

  <div class="atithi-luxury-prose-container">
    <p><%= data.description %></p>
  </div>

  <% if (currUser && data.owner && currUser._id.equals(data.owner._id)){ %>
    <div class="atithi-luxury-admin-deck">
      <a href="/listings/<%= data._id %>/edit" class="btn-luxury-operational-lever btn-luxury-lever-modify">
        <i class="bi bi-sliders2"></i> Edit Configurations
      </a>
      
      <form method="POST" action="/listings/<%= data._id %>?_method=DELETE" class="m-0">
        <button type="submit" class="btn-luxury-operational-lever btn-luxury-lever-delete">
          <i class="bi bi-trash3"></i> Delete Space Node
        </button>
      </form>
    </div>
  <% } %>

</div>